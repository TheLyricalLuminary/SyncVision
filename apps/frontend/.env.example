# =========================================================
# SyncVision Frontend — Build-time Environment Variables
# =========================================================
# Copy this file to .env.local (local dev) or set in Render build settings.
# NEVER commit .env.local or .env.production with real values.
# All variables must be prefixed VITE_ to be visible to the browser bundle.
#
# Legend:
#   [REQUIRED] — build will warn / OG tags break if missing
#   [OPTIONAL] — safe to omit; feature disabled or has a fallback
# =========================================================

# [REQUIRED] Public URL of this frontend — used for Open Graph / Twitter Card
# meta tags that generate LinkedIn/social link previews.
# Must be the exact browser-visible URL (no trailing slash).
# Example: https://syncvision-frontend.onrender.com
VITE_APP_URL="http://localhost:5174"

# [OPTIONAL] Backend API base URL.
# In local dev, leave empty — Vite proxies /api to localhost:3001.
# In production, set to the public backend URL.
# Example: https://syncvision-backend.onrender.com
VITE_API_URL=""
