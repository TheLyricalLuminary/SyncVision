// ─── Shared UI atoms ──────────────────────────────────────────────────────────

function Badge({ label, bg, fg }: { label: string; bg: string; fg: string }) {
  return (
    <span className="sv-badge" style={{ background: bg, color: fg }}>{label}</span>
  )
}

function Stat({ label, value, color }: { label: string; value: React.ReactNode; color?: string }) {
  return (
    <div style={{ background: 'var(--bg-2)', borderRadius: 8, padding: '10px 12px' }}>
      <p style={{ fontSize: 11, fontWeight: 500, color: 'var(--text-3)', textTransform: 'uppercase', letterSpacing: '0.06em', margin: '0 0 4px' }}>{label}</p>
      <div style={{ fontSize: 20, fontWeight: 500, color: color ?? 'var(--text)', margin: 0, lineHeight: 1.2 }}>{value}</div>
    </div>
  )
}

function PlayButton({ trackId }: { trackId: string }) {
  const [playing, setPlaying] = useState(false)
  const audioRef = useRef<HTMLAudioElement | null>(null)

  function toggle(e: React.MouseEvent) {
    e.stopPropagation()
    if (!audioRef.current) {
      const el = new Audio(`${API_BASE}/api/tracks/${trackId}/audio`)
      el.onended = () => setPlaying(false)
      el.onpause = () => setPlaying(false)
      el.onplay  = () => setPlaying(true)
      audioRef.current = el
    }
    const el = audioRef.current
    if (playing) {
      el.pause()
    } else {
      if (currentAudio.el && currentAudio.el !== el) currentAudio.el.pause()
      currentAudio.el = el
      el.play().catch(() => {})
    }
  }

  useEffect(() => { return () => { audioRef.current?.pause() } }, [])

  return (
    <button
      onClick={toggle}
      title={playing ? 'Pause' : 'Play'}
      style={{
        width: 28, height: 28, borderRadius: '50%',
        background: playing ? 'var(--text)' : 'var(--bg-2)',
        border: '0.5px solid var(--border-2)',
        color: playing ? 'var(--bg)' : 'var(--text-2)',
        display: 'flex', alignItems: 'center', justifyContent: 'center',
        flexShrink: 0, fontSize: 10,
      }}
    >
      {playing ? '⏸' : '▶'}
    </button>
  )
}

// ─── Nav bar ──────────────────────────────────────────────────────────────────

function Nav({
  left, right, subtitle,
}: {
  left?: React.ReactNode
  right?: React.ReactNode
  subtitle?: string
}) {
  return (
    <div style={{
      display: 'flex', alignItems: 'center', justifyContent: 'space-between',
      padding: '10px 16px',
      background: 'var(--bg)',
      borderBottom: '0.5px solid var(--border)',
    }}>
      <div style={{ display: 'flex', alignItems: 'center', gap: 8 }}>
        {left}
        {subtitle && (
          <span style={{ fontSize: 13, color: 'var(--text-2)' }}>{subtitle}</span>
        )}
      </div>
      {right}
    </div>
  )
}

function BackButton({ label, onClick }: { label: string; onClick: () => void }) {
  return (
    <button
      onClick={onClick}
      style={{
        display: 'flex', alignItems: 'center', gap: 4,
        fontSize: 12, padding: '4px 10px',
        background: 'var(--bg-2)', border: '0.5px solid var(--border-2)',
        borderRadius: 6, color: 'var(--text-2)',
      }}
    >
      ← {label}
    </button>
  )
}

function PrimaryButton({ label, onClick, disabled }: { label: string; onClick: () => void; disabled?: boolean }) {
  return (
    <button
      onClick={onClick}
      disabled={disabled}
      style={{
        fontSize: 13, fontWeight: 500, padding: '8px 20px',
        background: disabled ? 'var(--border)' : 'var(--text)',
        color: disabled ? 'var(--text-3)' : 'var(--bg)',
        border: 'none', borderRadius: 8,
        opacity: disabled ? 0.6 : 1,
      }}
    >
      {label}
    </button>
  )
}

// ─── Scene match row ──────────────────────────────────────────────────────────

function SceneMatchRow({
  match,
  delta,
  onSelect,
}: {
  match: SceneMatch
  delta: number | null
  onSelect: () => void
}) {
  const [expanded, setExpanded] = useState(false)
  const pass = passLabel(match.matchScore)
  const frag = fragmentationLabel(match.isOneStop, match.matchScore)
  const cut  = cutRisk(match.breakdown)
  const over = overexposureRisk(match.matchScore)
  const drift = driftRisk(match.breakdown)

  return (
    <div className="sv-track-row" style={{ flexDirection: 'column', gap: 0, padding: 0 }}>
      {/* Main row */}
      <div style={{ display: 'flex', alignItems: 'flex-start', gap: 10, padding: '10px 0', width: '100%' }}>
        <span style={{ fontSize: 11, color: 'var(--text-3)', paddingTop: 2, minWidth: 18, textAlign: 'right', flexShrink: 0 }}>
          {match.rank}
        </span>
        <PlayButton trackId={match.trackId} />
        <div style={{ flex: 1, minWidth: 0 }}>
          {/* Title row */}
          <div style={{ display: 'flex', alignItems: 'center', gap: 6, flexWrap: 'wrap', marginBottom: 3 }}>
            <span style={{ fontSize: 14, fontWeight: 500, color: 'var(--text)' }}>{match.title}</span>
            {match.artistName && (
              <span style={{ fontSize: 12, color: 'var(--text-3)' }}>{match.artistName}</span>
            )}
            <Badge label={`${pass.label} · ${match.matchScore}`} bg={pass.bg} fg={pass.fg} />
            <Badge label={frag.label} bg={frag.bg} fg={frag.fg} />
          </div>
          {/* Score bar + delta */}
          <div style={{ display: 'flex', alignItems: 'center', gap: 8, marginBottom: 5 }}>
            <div style={{ flex: 1, background: 'var(--bg-2)', borderRadius: 3, height: 3 }}>
              <div style={{ width: `${match.matchScore}%`, height: 3, background: barColor(match.matchScore), borderRadius: 3 }} />
            </div>
            {delta !== null && (
              <span style={{ fontSize: 11, color: 'var(--text-3)', whiteSpace: 'nowrap' }}>
                +{delta.toFixed(1)} vs #{match.rank + 1}
              </span>
            )}
          </div>
          {/* Narrative */}
          <p style={{ fontSize: 12, color: 'var(--text-2)', margin: '0 0 5px', lineHeight: 1.5 }}>
            {match.sonicNarrative}
          </p>
          {/* Risk row */}
          <div style={{ display: 'flex', gap: 6 }}>
            <span style={{ fontSize: 11, color: 'var(--text-3)' }}>
              Cut risk <span style={{ color: riskColor(cut) }}>{cut}</span>
            </span>
            <span style={{ fontSize: 11, color: 'var(--text-3)' }}>·</span>
            <span style={{ fontSize: 11, color: 'var(--text-3)' }}>
              Overexposure <span style={{ color: riskColor(over) }}>{over}</span>
            </span>
            <span style={{ fontSize: 11, color: 'var(--text-3)' }}>·</span>
            <span style={{ fontSize: 11, color: 'var(--text-3)' }}>
              Drift <span style={{ color: riskColor(drift) }}>{drift}</span>
            </span>
          </div>
        </div>
        <button
          onClick={(e) => { e.stopPropagation(); onSelect() }}
          style={{
            fontSize: 11, padding: '4px 10px', flexShrink: 0,
            background: 'var(--bg-2)', border: '0.5px solid var(--border-2)',
            borderRadius: 6, color: 'var(--text-2)',
          }}
        >
          Select
        </button>
      </div>
      {/* Optional audio preview (expand on row click, not select) */}
      <div
        onClick={() => setExpanded(p => !p)}
        style={{ width: '100%', cursor: 'pointer', paddingLeft: 46 }}
      >
        {expanded && (
          <audio
            controls
            preload="metadata"
            src={`${API_BASE}/api/tracks/${match.trackId}/audio`}
            style={{ width: '100%', marginBottom: 8, borderRadius: 6 }}
            onClick={e => e.stopPropagation()}
          />
        )}
        {!expanded && (
          <span style={{ fontSize: 11, color: 'var(--blue)', display: 'none' }}></span>
        )}
      </div>
    </div>
  )
}

// ─── Decision Packet screen ───────────────────────────────────────────────────

function PacketScreen({
  match,
  rankedMatches,
  sceneLabel,
  onBack,
}: {
  match: SceneMatch
  rankedMatches: SceneMatch[]
  sceneLabel: string
  onBack: () => void
}) {
  const pass  = passLabel(match.matchScore)
  const frag  = fragmentationLabel(match.isOneStop, match.matchScore)
  const est   = clearanceEstimate(match.isOneStop, match.matchScore)
  const windows = usageWindows(match.isOneStop, match.matchScore)

  // Compute delta vs runner-up (only if we are rank 1)
  const next   = rankedMatches.find(m => m.rank === match.rank + 1)
  const delta  = next ? (match.matchScore - next.matchScore).toFixed(1) : null

  // Signals explaining rank superiority
  const signals: string[] = []
  if (match.breakdown.rights > (next?.breakdown.rights ?? 0) + 3) signals.push('Stronger rights profile')
  if (match.breakdown.metadata > (next?.breakdown.metadata ?? 0) + 2) signals.push('More complete metadata')
  if (match.matchScore - (next?.matchScore ?? 0) > 5) signals.push('Higher composite score')
  if (match.isOneStop && !next?.isOneStop) signals.push('One-stop verified')
  if (match.breakdown.audio > (next?.breakdown.audio ?? 0)) signals.push('Better audio alignment')
  if (signals.length === 0) signals.push('Stronger HEXAQA vector alignment')

  return (
    <div style={{ background: 'var(--bg-3)', minHeight: '100vh' }}>
      <Nav
        left={
          <>
            <BackButton label="Results" onClick={onBack} />
            <span style={{ fontSize: 13, color: 'var(--text-2)' }}>
              Decision packet — {match.title}
            </span>
          </>
        }
        right={
          <div style={{ display: 'flex', gap: 6 }}>
            <button style={{
              fontSize: 12, padding: '5px 12px', display: 'flex', alignItems: 'center', gap: 5,
              background: 'var(--bg-2)', border: '0.5px solid var(--border-2)',
              borderRadius: 6, color: 'var(--text-2)',
            }}>⎘ Copy</button>
            <button style={{
              fontSize: 12, padding: '5px 12px', display: 'flex', alignItems: 'center', gap: 5,
              fontWeight: 500, background: 'var(--text)', border: 'none',
              borderRadius: 6, color: 'var(--bg)',
            }}>↓ Export PDF</button>
          </div>
        }
      />
      <div style={{ padding: '14px 16px' }}>
        <div style={{ maxWidth: 560, margin: '0 auto' }}>

          {/* Header card */}
          <div style={{ background: 'var(--bg)', border: '0.5px solid var(--border)', borderRadius: 12, padding: '14px 16px', marginBottom: 10 }}>
            <div style={{ display: 'flex', alignItems: 'flex-start', justifyContent: 'space-between', marginBottom: 12 }}>
              <div>
                <p style={{ fontSize: 16, fontWeight: 500, margin: 0, color: 'var(--text)' }}>{match.title}</p>
                <p style={{ fontSize: 13, color: 'var(--text-2)', margin: '2px 0 0' }}>
                  {match.artistName} · {match.isrc}
                </p>
              </div>
              <Badge label={pass.label} bg={pass.bg} fg={pass.fg} />
            </div>

            {/* Stats row */}
            <div style={{ display: 'grid', gridTemplateColumns: 'repeat(3, 1fr)', gap: 8, marginBottom: 12 }}>
              <Stat label="Match score" value={<span style={{ fontSize: 22, fontWeight: 500 }}>{match.matchScore}</span>} />
              <Stat label="Rights" value={<span style={{ fontSize: 14, fontWeight: 500, color: frag.fg }}>{frag.label}</span>} />
              <Stat label="Est. window" value={<span style={{ fontSize: 14, fontWeight: 500 }}>{est}</span>} />
            </div>

            {/* Supervisor rationale */}
            <div style={{ background: 'var(--bg-2)', borderRadius: 8, padding: '10px 12px', marginBottom: 10 }}>
              <p style={{ fontSize: 11, fontWeight: 500, color: 'var(--text-3)', textTransform: 'uppercase', letterSpacing: '0.06em', margin: '0 0 4px' }}>
                Supervisor rationale
              </p>
              <p style={{ fontSize: 13, color: 'var(--text)', margin: 0, lineHeight: 1.6 }}>
                {match.sonicNarrative}
              </p>
            </div>

            {/* Why ranked here */}
            {next && delta && (
              <div style={{ borderTop: '0.5px solid var(--border)', paddingTop: 10 }}>
                <p style={{ fontSize: 11, fontWeight: 500, color: 'var(--text-3)', textTransform: 'uppercase', letterSpacing: '0.06em', margin: '0 0 6px' }}>
                  Why ranked #{match.rank} over {next.title} (+{delta} delta)
                </p>
                <div style={{ display: 'flex', gap: 6, flexWrap: 'wrap' }}>
                  {signals.map(s => (
                    <Badge key={s} label={s} bg="var(--neutral-bg)" fg="var(--text-2)" />
                  ))}
                </div>
              </div>
            )}
          </div>

          {/* Usage windows */}
          <div style={{ background: 'var(--bg)', border: '0.5px solid var(--border)', borderRadius: 12, padding: '14px 16px', marginBottom: 10 }}>
            <p style={{ fontSize: 11, fontWeight: 500, color: 'var(--text-3)', textTransform: 'uppercase', letterSpacing: '0.06em', margin: '0 0 8px' }}>Usage windows</p>
            <div style={{ display: 'grid', gridTemplateColumns: 'repeat(4, 1fr)', gap: 6 }}>
              {windows.map(w => (
                <div key={w.label} style={{ textAlign: 'center', background: w.bg, borderRadius: 8, padding: '8px 4px' }}>
                  <span style={{ fontSize: 16, display: 'block', marginBottom: 3 }}>{w.icon}</span>
                  <p style={{ fontSize: 11, fontWeight: 500, margin: 0, color: w.fg }}>{w.label}</p>
                  <p style={{ fontSize: 10, margin: '1px 0 0', color: w.iconColor }}>{w.status}</p>
                </div>
              ))}
            </div>
          </div>

          {/* Score breakdown */}
          <div style={{ background: 'var(--bg)', border: '0.5px solid var(--border)', borderRadius: 12, padding: '14px 16px', marginBottom: 10 }}>
            <p style={{ fontSize: 11, fontWeight: 500, color: 'var(--text-3)', textTransform: 'uppercase', letterSpacing: '0.06em', margin: '0 0 10px' }}>Score breakdown</p>
            {(Object.keys(BREAKDOWN_MAXES) as Array<keyof Breakdown>).map(key => {
              const pct = Math.round((match.breakdown[key] / BREAKDOWN_MAXES[key]) * 100)
              return (
                <div key={key} style={{ marginBottom: 8 }}>
                  <div style={{ display: 'flex', justifyContent: 'space-between', marginBottom: 3 }}>
                    <span style={{ fontSize: 12, color: 'var(--text-2)' }}>{BREAKDOWN_LABELS[key]}</span>
                    <span style={{ fontSize: 12, color: 'var(--text)' }}>{match.breakdown[key]} / {BREAKDOWN_MAXES[key]}</span>
                  </div>
                  <div style={{ background: 'var(--bg-2)', borderRadius: 3, height: 3 }}>
                    <div style={{ width: `${pct}%`, height: 3, background: barColor(pct), borderRadius: 3 }} />
                  </div>
                </div>
              )
            })}
          </div>

          {/* Audit log */}
          <div style={{ background: 'var(--bg)', border: '0.5px solid var(--border)', borderRadius: 12, padding: '14px 16px', marginBottom: 10 }}>
            <p style={{ fontSize: 11, fontWeight: 500, color: 'var(--text-3)', textTransform: 'uppercase', letterSpacing: '0.06em', margin: '0 0 8px' }}>Audit log</p>
            {[
              ['Brief',         sceneLabel],
              ['Input hash',    match.inputHash.slice(0, 8) + '…' + match.inputHash.slice(-4)],
              ['Track ID',      match.trackId],
              ['ISRC',          match.isrc],
            ].map(([label, val]) => (
              <div key={label} style={{ display: 'flex', justifyContent: 'space-between', padding: '5px 0', borderBottom: '0.5px solid var(--border)', fontSize: 12 }}>
                <span style={{ color: 'var(--text-2)' }}>{label}</span>
                <span style={{ fontFamily: 'var(--font-mono)', color: 'var(--text)', fontSize: 11 }}>{val}</span>
              </div>
            ))}
          </div>

          <p style={{ fontSize: 11, color: 'var(--text-3)', margin: '4px 0 0', lineHeight: 1.5 }}>
            *Clearance estimates based on rights profile completeness. Actual clearance requires rights holder confirmation.
          </p>
        </div>
      </div>
    </div>
  )
}

// ─── Brief intake screen (was "scenes") ──────────────────────────────────────

function BriefIntakeScreen({
  onRunScene,
  onUpload,
  onComposer,
  onViewAll,
  onRoi,
  onPricing,
  onRights,
  onAnalytics,
}: {
  onRunScene: (id: string, label: string) => void
  onUpload: () => void
  onComposer: () => void
  onViewAll: () => void
  onRoi: () => void
  onPricing: () => void
  onRights: () => void
  onAnalytics: () => void
}) {
  const [activeScene, setActiveScene] = useState<string>(SCENES[0].id)
  const [description, setDescription] = useState<string>('')

  const scene = SCENES.find(s => s.id === activeScene) ?? SCENES[0]

  return (
    <div style={{ background: 'var(--bg-3)', minHeight: '100vh' }}>
      {/* Top nav */}
      <Nav
        left={<span style={{ fontSize: 13, fontWeight: 500, color: 'var(--text)' }}>SyncVision</span>}
        right={
          <div style={{ display: 'flex', alignItems: 'center', gap: 8 }}>
            <span style={{ fontSize: 12, color: 'var(--text-3)' }}>Pre-clearance risk engine</span>
            <div style={{
              width: 28, height: 28, borderRadius: '50%',
              background: 'var(--purple-bg)', display: 'flex', alignItems: 'center',
              justifyContent: 'center', fontSize: 11, fontWeight: 500, color: 'var(--purple-fg)',
            }}>SV</div>
          </div>
        }
      />

      <div style={{ padding: '20px 16px' }}>
        <div style={{ maxWidth: 560, margin: '0 auto' }}>
          <p style={{ fontSize: 18, fontWeight: 500, margin: '0 0 4px', color: 'var(--text)' }}>New brief evaluation</p>
          <p style={{ fontSize: 13, color: 'var(--text-2)', margin: '0 0 18px' }}>
            Select a scene type or describe the moment. Returns a risk-ranked shortlist with delta vs alternatives.
          </p>

          {/* Brief type + description card */}
          <div style={{ background: 'var(--bg)', border: '0.5px solid var(--border)', borderRadius: 12, padding: '14px 16px', marginBottom: 12 }}>
            <p style={{ fontSize: 11, fontWeight: 500, color: 'var(--text-3)', textTransform: 'uppercase', letterSpacing: '0.06em', margin: '0 0 6px' }}>Brief type</p>
            <div className="scene-grid" style={{ marginBottom: 14 }}>
              {SCENES.map(s => (
                <button
                  key={s.id}
                  className={'sv-pill' + (activeScene === s.id ? ' active' : '')}
                  onClick={() => setActiveScene(s.id)}
                >
                  {s.label}
                </button>
              ))}
            </div>

            <p style={{ fontSize: 11, fontWeight: 500, color: 'var(--text-3)', textTransform: 'uppercase', letterSpacing: '0.06em', margin: '0 0 6px' }}>Scene description</p>
            <textarea
              value={description || scene.label}
              onChange={e => setDescription(e.target.value)}
              rows={3}
              style={{
                width: '100%', fontSize: 13, resize: 'none', padding: '10px 12px',
                borderRadius: 8, border: '0.5px solid var(--border-2)',
                background: 'var(--bg-2)', color: 'var(--text)',
                fontFamily: 'var(--font)', lineHeight: 1.5,
              }}
            />

            <div style={{ display: 'flex', alignItems: 'center', justifyContent: 'space-between', marginTop: 10 }}>
              <div style={{ display: 'flex', gap: 8 }}>
                <div style={{ background: 'var(--bg-2)', borderRadius: 8, padding: '6px 10px', display: 'flex', alignItems: 'center', gap: 6 }}>
                  <span style={{ fontSize: 14, color: 'var(--text-3)' }}>♪</span>
                  <span style={{ fontSize: 12, color: 'var(--text-2)' }}>847 tracks scored</span>
                </div>
                <div style={{ background: 'var(--bg-2)', borderRadius: 8, padding: '6px 10px', display: 'flex', alignItems: 'center', gap: 6 }}>
                  <span style={{ fontSize: 14, color: 'var(--text-3)' }}>⏱</span>
                  <span style={{ fontSize: 12, color: 'var(--text-2)' }}>~3 sec</span>
                </div>
              </div>
              <PrimaryButton label="Run evaluation" onClick={() => onRunScene(activeScene, scene.label)} />
            </div>
          </div>

          {/* Filters card */}
          <div style={{ background: 'var(--bg)', border: '0.5px solid var(--border)', borderRadius: 12, padding: '14px 16px', marginBottom: 20 }}>
            <div style={{ display: 'grid', gridTemplateColumns: 'repeat(3, 1fr)', gap: 12 }}>
              {[
                { label: 'Catalog', options: ['All catalogs', 'Sony ATV Library', 'My uploads'] },
                { label: 'Rights filter', options: ['Any fragmentation', 'Low fragmentation only', 'One-stop verified'] },
                { label: 'Usage type', options: ['TV / streaming', 'Film', 'Trailer', 'Ad'] },
              ].map(({ label, options }) => (
                <div key={label}>
                  <p style={{ fontSize: 11, fontWeight: 500, color: 'var(--text-3)', textTransform: 'uppercase', letterSpacing: '0.06em', margin: '0 0 4px' }}>{label}</p>
                  <select style={{
                    width: '100%', fontSize: 13, padding: '6px 8px', borderRadius: 6,
                    border: '0.5px solid var(--border-2)', background: 'var(--bg-2)',
                    color: 'var(--text)',
                  }}>
                    {options.map(o => <option key={o}>{o}</option>)}
                  </select>
                </div>
              ))}
            </div>
          </div>

          {/* Secondary actions */}
          <div style={{ display: 'flex', flexWrap: 'wrap', gap: 8 }}>
            {[
              { label: '+ Add tracks', onClick: onUpload, primary: true },
              { label: 'All tracks', onClick: onViewAll },
              { label: 'Composer report', onClick: onComposer },
              { label: 'Rights evaluation', onClick: onRights },
              { label: 'Catalog analytics', onClick: onAnalytics },
              { label: 'ROI calculator', onClick: onRoi },
              { label: 'Pricing', onClick: onPricing },
            ].map(({ label, onClick, primary }) => (
              <button
                key={label}
                onClick={onClick}
                style={{
                  fontSize: 12, padding: '6px 14px',
                  background: primary ? 'var(--text)' : 'var(--bg)',
                  color: primary ? 'var(--bg)' : 'var(--text-2)',
                  border: primary ? 'none' : '0.5px solid var(--border-2)',
                  borderRadius: 20, fontWeight: primary ? 500 : 400,
                }}
              >
                {label}
              </button>
            ))}
          </div>
        </div>
      </div>
    </div>
  )
}

// ─── Results screen (ranked shortlist) ───────────────────────────────────────

type ResultFilter = 'all' | 'pass' | 'low-friction'

function ResultsScreen({
  sceneData,
  loading,
  error,
  onBack,
  onSelectMatch,
  onExport,
}: {
  sceneData: SceneResponse | null
  loading: boolean
  error: string | null
  onBack: () => void
  onSelectMatch: (match: SceneMatch) => void
  onExport: () => void
}) {
  const [filter, setFilter] = useState<ResultFilter>('all')
  const matches = sceneData?.rankedMatches ?? []

  const filtered = matches.filter(m => {
    if (filter === 'pass') return m.matchScore >= 60
    if (filter === 'low-friction') return m.isOneStop && m.matchScore >= 70
    return true
  })

  const passStrong = matches.filter(m => m.matchScore >= 80).length
  const lowFrag    = matches.filter(m => m.isOneStop).length
  const readyPitch = matches.filter(m => m.isOneStop && m.matchScore >= 80).length
  const topScore   = matches[0]?.matchScore ?? 0

  return (
    <div style={{ background: 'var(--bg-3)', minHeight: '100vh' }}>
      <Nav
        left={
          <>
            <BackButton label="Brief" onClick={onBack} />
            <span style={{ fontSize: 13, color: 'var(--text-2)' }}>
              {sceneData?.sceneLabel ?? '…'} · {matches.length} evaluated ·{' '}
              <span style={{ color: 'var(--text)', fontWeight: 500 }}>{passStrong} PASS_STRONG</span>
            </span>
          </>
        }
        right={
          <button
            onClick={onExport}
            style={{
              fontSize: 12, padding: '5px 12px', display: 'flex', alignItems: 'center', gap: 5,
              fontWeight: 500, background: 'var(--text)', border: 'none',
              borderRadius: 6, color: 'var(--bg)',
            }}
          >
            ↓ Export packet
          </button>
        }
      />

      <div style={{ padding: '14px 16px' }}>
        {/* Stats summary */}
        {!loading && matches.length > 0 && (
          <div style={{ display: 'grid', gridTemplateColumns: 'repeat(4, 1fr)', gap: 8, marginBottom: 14 }}>
            <Stat label="Top score" value={topScore} />
            <Stat label="PASS_STRONG" value={passStrong} color="var(--pass-fg)" />
            <Stat label="Low fragmentation" value={lowFrag} />
            <Stat label="Ready to pitch" value={readyPitch} />
          </div>
        )}

        {loading && (
          <div style={{ color: 'var(--text-3)', textAlign: 'center', padding: '60px 0', fontSize: 15 }}>
            Fetching matches…
          </div>
        )}

        {error && !loading && (
          <div style={{ background: 'var(--high-bg)', border: '0.5px solid var(--high-fg)', borderRadius: 10, padding: 20, color: 'var(--high-fg)', textAlign: 'center' }}>
            <strong>Error:</strong> {error}
          </div>
        )}

        {!loading && !error && matches.length > 0 && (
          <div style={{ background: 'var(--bg)', border: '0.5px solid var(--border)', borderRadius: 12, padding: '0 14px 10px' }}>
            {/* Tab bar */}
            <div style={{ display: 'flex', borderBottom: '0.5px solid var(--border)', marginBottom: 0 }}>
              {(['all', 'pass', 'low-friction'] as const).map(f => (
                <button
                  key={f}
                  className={'sv-tab' + (filter === f ? ' active' : '')}
                  onClick={() => setFilter(f)}
                >
                  {f === 'all' ? 'All results' : f === 'pass' ? 'PASS only' : 'Low friction'}
                </button>
              ))}
            </div>

            {filtered.map((match, i) => {
              const next   = filtered[i + 1]
              const delta  = next ? match.matchScore - next.matchScore : null
              return (
                <SceneMatchRow
                  key={match.trackId}
                  match={match}
                  delta={delta}
                  onSelect={() => onSelectMatch(match)}
                />
              )
            })}

            {matches.length > filtered.length && (
              <div style={{ padding: '10px 0 0', textAlign: 'center' }}>
                <span style={{ fontSize: 12, color: 'var(--text-3)' }}>
                  {matches.length - filtered.length} results hidden by filter
                </span>
              </div>
            )}
          </div>
        )}

        <p style={{ fontSize: 11, color: 'var(--text-3)', margin: '10px 0 0' }}>
          *Clearance estimates based on rights profile completeness. Actual clearance requires rights holder confirmation.
        </p>
      </div>
    </div>
  )
}

// ─── Composer report screen ───────────────────────────────────────────────────

function ComposerReportScreen({ onBack }: { onBack: () => void }) {
  const [report, setReport]   = useState<ComposerReport | null>(null)
  const [loading, setLoading] = useState(false)
  const [error, setError]     = useState<string | null>(null)
  const [selectedId, setSelectedId] = useState<string | null>(null)

  useEffect(() => {
    setLoading(true)
    fetch(`${API_BASE}/api/composer-report`)
      .then(r => { if (!r.ok) throw new Error(`HTTP ${r.status}`); return r.json() as Promise<ComposerReport> })
      .then(setReport)
      .catch((e: Error) => setError(e.message))
      .finally(() => setLoading(false))
  }, [])

  const selected = report?.tracks.find(t => t.trackId === selectedId) ?? report?.tracks[0] ?? null

  const SEVERITY_STYLES: Record<string, { bg: string; fg: string; icon: string }> = {
    CRITICAL: { bg: 'var(--high-bg)',  fg: 'var(--high-fg)', icon: '✕' },
    HIGH:     { bg: 'var(--mod-bg)',   fg: 'var(--mod-fg)',  icon: '△' },
    MEDIUM:   { bg: 'var(--mod-bg)',   fg: 'var(--mod-fg)',  icon: '△' },
  }

  return (
    <div style={{ background: 'var(--bg-3)', minHeight: '100vh' }}>
      <Nav
        left={
          <>
            <BackButton label="Brief" onClick={onBack} />
            <span style={{ fontSize: 13, color: 'var(--text-2)' }}>Composer · sync readiness</span>
          </>
        }
        right={
          <button style={{
            fontSize: 12, padding: '5px 12px', display: 'flex', alignItems: 'center', gap: 5,
            fontWeight: 500, background: 'var(--text)', border: 'none', borderRadius: 6, color: 'var(--bg)',
          }}>↓ Export report</button>
        }
      />

      <div style={{ padding: '14px 16px' }}>
        {loading && (
          <div style={{ color: 'var(--text-3)', textAlign: 'center', padding: '60px 0', fontSize: 15 }}>Loading report…</div>
        )}
        {error && (
          <div style={{ background: 'var(--high-bg)', border: '0.5px solid var(--high-fg)', borderRadius: 10, padding: 20, color: 'var(--high-fg)', textAlign: 'center' }}>
            <strong>Error:</strong> {error}
          </div>
        )}

        {report && selected && (
          <div style={{ maxWidth: 560, margin: '0 auto' }}>
            {/* Track picker */}
            {report.tracks.length > 1 && (
              <div style={{ display: 'flex', gap: 6, flexWrap: 'wrap', marginBottom: 14 }}>
                {report.tracks.map(t => (
                  <button
                    key={t.trackId}
                    className={'sv-pill' + (selected.trackId === t.trackId ? ' active' : '')}
                    onClick={() => setSelectedId(t.trackId)}
                  >
                    {t.title}
                  </button>
                ))}
              </div>
            )}

            {/* Track header */}
            <div style={{ display: 'flex', alignItems: 'flex-start', justifyContent: 'space-between', marginBottom: 14 }}>
              <div>
                <p style={{ fontSize: 16, fontWeight: 500, margin: 0, color: 'var(--text)' }}>{selected.title}</p>
                <p style={{ fontSize: 13, color: 'var(--text-2)', margin: '2px 0 0' }}>
                  {selected.artistName ?? 'Unknown artist'} · uploaded {selected.uploadedAt ? new Date(selected.uploadedAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) : 'recently'}
                </p>
              </div>
            </div>

            {/* Stats */}
            <div style={{ display: 'grid', gridTemplateColumns: 'repeat(3, 1fr)', gap: 8, marginBottom: 14 }}>
              <Stat
                label="Sync readiness"
                value={
                  selected.syncReadiness !== null
                    ? <>{selected.syncReadiness}<span style={{ fontSize: 13, color: 'var(--text-3)' }}>/100</span></>
                    : '—'
                }
              />
              <Stat label="Best brief" value={<span style={{ fontSize: 13, fontWeight: 500 }}>{selected.bestBrief}</span>} />
              <Stat
                label="Metadata gaps"
                value={selected.gapCount}
                color={selected.gapCount === 0 ? 'var(--pass-fg)' : selected.gapCount >= 3 ? 'var(--high-fg)' : 'var(--mod-fg)'}
              />
            </div>

            {/* Brief score ranking */}
            <div style={{ background: 'var(--bg)', border: '0.5px solid var(--border)', borderRadius: 12, padding: '14px 16px', marginBottom: 10 }}>
              <p style={{ fontSize: 11, fontWeight: 500, color: 'var(--text-3)', textTransform: 'uppercase', letterSpacing: '0.06em', margin: '0 0 10px' }}>
                Brief score ranking — top placements
              </p>
              {selected.briefScores.map((bs, i) => (
                <div
                  key={bs.scene}
                  style={{
                    display: 'flex', alignItems: 'center', gap: 8,
                    padding: '7px 0', borderBottom: i < selected.briefScores.length - 1 ? '0.5px solid var(--border)' : 'none',
                  }}
                >
                  <span style={{ fontSize: 12, color: 'var(--text-3)', minWidth: 16 }}>{i + 1}</span>
                  <span style={{ fontSize: 13, color: 'var(--text)', minWidth: 160 }}>{bs.scene}</span>
                  <div style={{ flex: 1, background: 'var(--bg-2)', borderRadius: 3, height: 3 }}>
                    <div style={{ width: `${bs.score}%`, height: 3, background: barColor(bs.score), borderRadius: 3 }} />
                  </div>
                  <Badge label={String(bs.score)} bg={bs.score >= 75 ? 'var(--pass-bg)' : bs.score >= 55 ? 'var(--mod-bg)' : 'var(--high-bg)'} fg={bs.score >= 75 ? 'var(--pass-fg)' : bs.score >= 55 ? 'var(--mod-fg)' : 'var(--high-fg)'} />
                </div>
              ))}
              {selected.briefScores.length > 0 && (
                <p style={{ fontSize: 12, color: 'var(--text-3)', margin: '8px 0 0', borderTop: '0.5px solid var(--border)', paddingTop: 8 }}>
                  Focus submissions on {selected.bestBrief.toLowerCase()} and adjacent scene types.
                </p>
              )}
            </div>

            {/* Metadata gaps */}
            {selected.gapCount > 0 && (
              <div style={{ background: 'var(--bg)', border: '0.5px solid var(--border)', borderRadius: 12, padding: '14px 16px', marginBottom: 10 }}>
                <p style={{ fontSize: 11, fontWeight: 500, color: 'var(--text-3)', textTransform: 'uppercase', letterSpacing: '0.06em', margin: '0 0 8px' }}>
                  Metadata gaps blocking clearance
                </p>
                <div style={{ display: 'flex', flexDirection: 'column', gap: 6 }}>
                  {selected.metadataGaps.map((gap) => {
                    const s = SEVERITY_STYLES[gap.severity]
                    return (
                      <div key={gap.field} style={{ display: 'flex', alignItems: 'center', justifyContent: 'space-between', padding: '7px 10px', background: s.bg, borderRadius: 8 }}>
                        <div style={{ display: 'flex', alignItems: 'center', gap: 8 }}>
                          <span style={{ fontSize: 14, color: s.fg }}>{s.icon}</span>
                          <span style={{ fontSize: 13, color: s.fg }}>{gap.field}</span>
                        </div>
                        <span style={{ fontSize: 12, color: s.fg }}>{gap.impact}</span>
                      </div>
                    )
                  })}
                </div>
                {selected.projectedReadiness !== null && selected.syncReadiness !== null && (
                  <p style={{ fontSize: 12, color: 'var(--text-3)', margin: '10px 0 0' }}>
                    Resolving these gaps moves sync readiness from {selected.syncReadiness} → est. {selected.projectedReadiness} and unlocks additional clearance paths.
                  </p>
                )}
              </div>
            )}
          </div>
        )}
      </div>
    </div>
  )
}

// ─── All-tracks screen (existing, re-skinned) ─────────────────────────────────

function AllTrackScoreBar({ label, value, max }: { label: string; value: number; max: number }) {
  const pct = Math.round((value / max) * 100)
  return (
    <div style={{ marginBottom: 10 }}>
      <div style={{ display: 'flex', justifyContent: 'space-between', marginBottom: 4 }}>
        <span style={{ color: 'var(--text-2)', fontSize: 13 }}>{label}</span>
        <span style={{ color: 'var(--text)', fontSize: 13 }}>{value} / {max}</span>
      </div>
      <div style={{ background: 'var(--bg-2)', borderRadius: 4, height: 6 }}>
        <div style={{ background: 'var(--blue)', width: `${pct}%`, height: '100%', borderRadius: 4 }} />
      </div>
    </div>
  )
}

function AllTrackPlayButton({ trackId }: { trackId: string }) {
  const [playing, setPlaying] = useState(false)
  const audioRef = useRef<HTMLAudioElement | null>(null)

  function toggle(e: React.MouseEvent) {
    e.stopPropagation()
    if (!audioRef.current) {
      const el = new Audio(`${API_BASE}/api/tracks/${trackId}/audio`)
      el.onended = () => setPlaying(false)
      el.onpause = () => setPlaying(false)
      el.onplay  = () => setPlaying(true)
      audioRef.current = el
    }
    const el = audioRef.current
    if (playing) {
      el.pause()
    } else {
      if (currentAudio.el && currentAudio.el !== el) currentAudio.el.pause()
      currentAudio.el = el
      el.play().catch(() => {})
    }
  }
  useEffect(() => { return () => { audioRef.current?.pause() } }, [])
  return (
    <button
      onClick={toggle}
      style={{
        width: 36, height: 36, borderRadius: '50%',
        background: playing ? 'var(--blue)' : 'var(--bg-2)',
        border: '0.5px solid var(--border-2)', color: playing ? 'var(--bg)' : 'var(--text-2)',
        display: 'flex', alignItems: 'center', justifyContent: 'center', flexShrink: 0, fontSize: 13,
      }}
    >{playing ? '⏸' : '▶'}</button>
  )
}

function AllTrackCard({ track, expanded, onToggle }: { track: RankedTrack; expanded: boolean; onToggle: () => void }) {
  const pass = passLabel(track.score)
  const audioRef = useRef<HTMLAudioElement>(null)
  const [audioError, setAudioError] = useState(false)

  useEffect(() => {
    setAudioError(false)
    const el = audioRef.current
    if (!el) return
    el.pause(); el.currentTime = 0; el.load()
  }, [track.trackId])

  return (
    <div
      onClick={onToggle}
      style={{
        background: 'var(--bg)', borderRadius: 12, padding: 20, marginBottom: 8,
        cursor: 'pointer', border: expanded ? '0.5px solid var(--blue)' : '0.5px solid var(--border)',
        transition: 'border-color 200ms',
      }}
    >
      <div style={{ display: 'flex', alignItems: 'center', gap: 14 }}>
        <div style={{ fontSize: 28, fontWeight: 700, color: 'var(--blue)', minWidth: 32, textAlign: 'center', lineHeight: 1 }}>
          {track.rank}
        </div>
        <AllTrackPlayButton trackId={track.trackId} />
        <div style={{ flex: 1 }}>
          <div style={{ display: 'flex', alignItems: 'center', gap: 8, flexWrap: 'wrap' }}>
            <span style={{ color: 'var(--text)', fontWeight: 600, fontSize: 15 }}>{track.title}</span>
            <Badge label={pass.label} bg={pass.bg} fg={pass.fg} />
            {track.isOneStop && <Badge label="ONE-STOP" bg="var(--pass-bg)" fg="var(--pass-fg)" />}
          </div>
          {track.artistName && <div style={{ color: 'var(--text-2)', fontSize: 13, marginTop: 2 }}>{track.artistName}</div>}
          <div style={{ color: 'var(--text-3)', fontFamily: 'var(--font-mono)', fontSize: 12, marginTop: 2 }}>{track.isrc}</div>
        </div>
        <div style={{ textAlign: 'right', flexShrink: 0 }}>
          <div style={{ fontSize: 32, fontWeight: 900, color: 'var(--text)', lineHeight: 1, fontVariantNumeric: 'tabular-nums' }}>{track.score}</div>
          <div style={{ color: 'var(--text-3)', fontSize: 11, marginTop: 2 }}>CONFIDENCE</div>
        </div>
      </div>

      {expanded && (
        <div style={{ borderTop: '0.5px solid var(--border)', marginTop: 16, paddingTop: 16 }}>
          {!audioError && (
            <audio
              ref={audioRef} controls preload="metadata"
              src={`${API_BASE}/api/tracks/${track.trackId}/audio`}
              style={{ width: '100%', marginBottom: 16, borderRadius: 6 }}
              onError={() => setAudioError(true)}
            />
          )}
          <p style={{ color: 'var(--text-2)', fontSize: 14, lineHeight: 1.6, marginBottom: 20 }}>{track.explanation}</p>
          <div style={{ marginBottom: 20 }}>
            {(Object.keys(BREAKDOWN_MAXES) as Array<keyof Breakdown>).map(key => (
              <AllTrackScoreBar key={key} label={BREAKDOWN_LABELS[key]} value={track.breakdown[key]} max={BREAKDOWN_MAXES[key]} />
            ))}
          </div>
          {track.ascapWorkId && (
            <div style={{ marginBottom: 16 }}>
              <div style={{ color: 'var(--text-3)', fontSize: 12 }}>ASCAP Work ID</div>
              <div style={{ color: 'var(--text)', fontFamily: 'var(--font-mono)', fontSize: 13, marginTop: 2 }}>{track.ascapWorkId}</div>
            </div>
          )}
          <div>
            <div style={{ color: 'var(--text-3)', fontSize: 12 }}>Verification Hash</div>
            <div style={{ color: 'var(--text-3)', fontFamily: 'var(--font-mono)', fontSize: 11, wordBreak: 'break-all', marginTop: 4, lineHeight: 1.5 }}>{track.inputHash}</div>
            <p style={{ color: 'var(--text-3)', fontSize: 11, marginTop: 6, marginBottom: 0 }}>
              Deterministic — identical across every run. Any change indicates a system violation.
            </p>
          </div>
        </div>
      )}
    </div>
  )
}

// ─── Upload screen (re-skinned, logic preserved) ─────────────────────────────

const PREVIEWABLE_TYPES = new Set([
  'audio/mpeg', 'audio/mp3', 'audio/wav', 'audio/x-wav',
  'audio/flac', 'audio/x-flac', 'audio/aac', 'audio/mp4', 'audio/ogg',
])

function LocalAudioPlayer({ file }: { file: File }) {
  const [src] = useState(() => URL.createObjectURL(file))
  useEffect(() => { return () => URL.revokeObjectURL(src) }, [src])
  return (
    <audio controls preload="metadata" src={src}
      style={{ width: '100%', marginTop: 12, borderRadius: 6 }} />
  )
}

function UploadEntryRow({
  entry, onChange, onRemove, onQueue, onRetry, onDelete,
}: {
  entry: UploadEntry
  onChange: (id: string, patch: Partial<UploadEntry>) => void
  onRemove: (id: string) => void
  onQueue: (id: string) => void
  onRetry: (id: string) => void
  onDelete: (id: string) => void
}) {
  const [isEditing, setIsEditing]   = useState(false)
  const [isSaving, setIsSaving]     = useState(false)
  const [saveError, setSaveError]   = useState<string | null>(null)
  const origRef = useRef<Partial<UploadEntry> | null>(null)

  const badge      = STATUS_BADGES[entry.status]
  const isrcValid  = ISRC_REGEX.test(entry.isrc.trim())
  const titleValid = entry.title.trim().length > 0
  const isrcMissing = entry.isrc.trim().length === 0
  const canQueue   = entry.status === 'inspected' && isrcValid && titleValid
  const locked     = ['queueing','queued','analyzing','analyzed'].includes(entry.status)
  const effectiveLocked = locked && !isEditing

  function startEdit() {
    origRef.current = { title: entry.title, artistName: entry.artistName, ascapWorkId: entry.ascapWorkId, writerName: entry.writerName, publisherName: entry.publisherName, proAffiliation: entry.proAffiliation }
    setIsEditing(true); setSaveError(null)
  }
  function cancelEdit() {
    if (origRef.current) onChange(entry.id, origRef.current)
    origRef.current = null; setIsEditing(false); setSaveError(null)
  }
  async function saveEdit() {
    if (!entry.trackId) { origRef.current = null; setIsEditing(false); return }
    setIsSaving(true); setSaveError(null)
    try {
      const res = await fetch(`${API_BASE}/api/tracks/${entry.trackId}`, {
        method: 'PATCH', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ title: entry.title, artistName: entry.artistName, ascapWorkId: entry.ascapWorkId, writerName: entry.writerName, publisherName: entry.publisherName, proAffiliation: entry.proAffiliation }),
      })
      if (!res.ok) {
        const data = (await res.json().catch(() => ({}))) as { error?: string }
        throw new Error(data.error ?? `HTTP ${res.status}`)
      }
      origRef.current = null; setIsEditing(false)
    } catch (err) {
      setSaveError(err instanceof Error ? err.message : 'Save failed')
    } finally {
      setIsSaving(false)
    }
  }

  const inputStyle: CSSProperties = {
    background: 'var(--bg-input)', border: '0.5px solid var(--border-2)',
    borderRadius: 6, padding: '8px 10px', color: 'var(--text)', fontSize: 13,
    width: '100%', fontFamily: 'var(--font)',
  }
  const labelStyle: CSSProperties = {
    color: 'var(--text-3)', fontSize: 11, marginBottom: 4, display: 'block', letterSpacing: '0.03em',
  }

  return (
    <div style={{ background: 'var(--bg)', borderRadius: 12, padding: 16, marginBottom: 10, border: '0.5px solid var(--border)' }}>
      <div style={{ display: 'flex', alignItems: 'center', gap: 12, flexWrap: 'wrap' }}>
        <div style={{ flex: 1, minWidth: 0 }}>
          <div style={{ color: 'var(--text)', fontWeight: 500, fontSize: 14, overflow: 'hidden', textOverflow: 'ellipsis', whiteSpace: 'nowrap' }}>
            {entry.file.name}
          </div>
          <div style={{ color: 'var(--text-3)', fontSize: 12, marginTop: 2 }}>{formatBytes(entry.file.size)}</div>
        </div>
        <Badge label={badge.label} bg={badge.bg} fg={badge.fg} />
        {locked && entry.trackId && (
          <div style={{ display: 'flex', gap: 6, alignItems: 'center' }}>
            {isEditing ? (
              <>
                <button onClick={() => void saveEdit()} disabled={isSaving}
                  style={{ background: 'var(--blue)', color: 'var(--bg)', border: 'none', borderRadius: 6, padding: '4px 12px', fontSize: 12, fontWeight: 500 }}>
                  {isSaving ? 'Saving…' : 'Save'}
                </button>
                <button onClick={cancelEdit}
                  style={{ background: 'transparent', border: '0.5px solid var(--border-2)', color: 'var(--text-2)', borderRadius: 6, padding: '4px 10px', fontSize: 12 }}>
                  Cancel
                </button>
              </>
            ) : (
              <button onClick={startEdit}
                style={{ background: 'transparent', border: '0.5px solid var(--border-2)', color: 'var(--text-2)', borderRadius: 6, padding: '4px 10px', fontSize: 12 }}>
                Edit
              </button>
            )}
            <button onClick={() => onDelete(entry.id)}
              style={{ background: 'transparent', border: '0.5px solid var(--high-fg)', color: 'var(--high-fg)', borderRadius: 6, padding: '4px 10px', fontSize: 12 }}>
              Delete
            </button>
          </div>
        )}
        {!locked && entry.status !== 'queueing' && (
          <button onClick={() => onRemove(entry.id)} aria-label="Remove file"
            style={{ background: 'transparent', border: '0.5px solid var(--border-2)', color: 'var(--text-2)', borderRadius: 6, width: 28, height: 28, fontSize: 14 }}>
            ×
          </button>
        )}
      </div>

      {PREVIEWABLE_TYPES.has(entry.file.type) && <LocalAudioPlayer file={entry.file} />}

      {entry.status === 'uploading' && (
        <div style={{ marginTop: 12 }}>
          <div style={{ background: 'var(--bg-2)', borderRadius: 4, height: 6, overflow: 'hidden' }}>
            <div style={{ background: 'var(--blue)', width: `${entry.uploadProgress}%`, height: '100%', transition: 'width 120ms linear' }} />
          </div>
          <div style={{ color: 'var(--text-3)', fontSize: 11, marginTop: 4 }}>{entry.uploadProgress}%</div>
        </div>
      )}

      {entry.status === 'inspect-failed' && (
        <div style={{ color: 'var(--high-fg)', fontSize: 13, marginTop: 12 }}>
          Upload failed: {entry.uploadError ?? 'unknown error'}
        </div>
      )}

      {(entry.status === 'inspected' || entry.status === 'queueing') && (
        <div style={{ marginTop: 16 }}>
          <div style={{ display: 'grid', gridTemplateColumns: '1fr 1fr', gap: 12 }}>
            {[
              { field: 'title', label: 'TITLE *', placeholder: '' },
              { field: 'artistName', label: 'ARTIST NAME', placeholder: '' },
            ].map(({ field, label, placeholder }) => (
              <div key={field}>
                <label style={labelStyle}>{label}</label>
                <input value={(entry as any)[field]} onChange={e => onChange(entry.id, { [field]: e.target.value })} disabled={effectiveLocked} style={inputStyle} placeholder={placeholder} />
              </div>
            ))}
            <div>
              <label style={labelStyle}>
                ISRC *
                {entry.isrcSource === 'detected' && <span style={{ marginLeft: 6, color: 'var(--pass-fg)', fontSize: 10, fontWeight: 600 }}>DETECTED</span>}
              </label>
              <input
                value={entry.isrc}
                onChange={e => onChange(entry.id, { isrc: e.target.value.toUpperCase(), isrcSource: 'manual' })}
                placeholder="e.g. QZTAW2599999"
                disabled={effectiveLocked}
                style={{ ...inputStyle, fontFamily: 'var(--font-mono)', borderColor: entry.isrc && !isrcValid ? 'var(--high-fg)' : undefined }}
              />
              {isrcMissing && <div style={{ color: 'var(--high-fg)', fontSize: 11, marginTop: 4 }}>ISRC required before clearance.</div>}
              {!isrcMissing && !isrcValid && <div style={{ color: 'var(--high-fg)', fontSize: 11, marginTop: 4 }}>Invalid format (12 chars, e.g. QZTAW2599999).</div>}
            </div>
            {[
              { field: 'ascapWorkId', label: 'ASCAP WORK ID', placeholder: '' },
              { field: 'writerName', label: 'WRITER NAME', placeholder: '' },
              { field: 'publisherName', label: 'PUBLISHER NAME', placeholder: '' },
              { field: 'proAffiliation', label: 'PRO AFFILIATION', placeholder: 'ASCAP, BMI, SESAC…' },
            ].map(({ field, label, placeholder }) => (
              <div key={field}>
                <label style={labelStyle}>{label}</label>
                <input value={(entry as any)[field]} onChange={e => onChange(entry.id, { [field]: e.target.value })} disabled={effectiveLocked} style={inputStyle} placeholder={placeholder} />
              </div>
            ))}
          </div>

          {/* Master ownership */}
          <div style={{ marginTop: 14, paddingTop: 14, borderTop: '0.5px solid var(--border)' }}>
            <div style={{ fontSize: 11, fontWeight: 600, color: 'var(--text-3)', letterSpacing: '0.08em', marginBottom: 10 }}>MASTER OWNERSHIP</div>
            <div style={{ display: 'grid', gridTemplateColumns: '1fr 1fr', gap: 12 }}>
              <div>
                <label style={labelStyle}>MASTER OWNER <span style={{ color: 'var(--high-fg)' }}>*</span></label>
                <input value={entry.masterOwnedBy} onChange={e => onChange(entry.id, { masterOwnedBy: e.target.value })} placeholder="Legal name" disabled={effectiveLocked} style={inputStyle} />
              </div>
              <div>
                <label style={labelStyle}>OWNERSHIP TYPE <span style={{ color: 'var(--high-fg)' }}>*</span></label>
                <select value={entry.masterOwnershipType} onChange={e => onChange(entry.id, { masterOwnershipType: e.target.value })} disabled={effectiveLocked}
                  style={{ ...inputStyle, appearance: 'none' as const }}>
                  <option value="">— Select —</option>
                  <option value="SELF_OWNED">Self-Owned</option>
                  <option value="LABEL">Label</option>
                  <option value="CO_OWNED">Co-Owned</option>
                  <option value="WORK_FOR_HIRE">Work-for-Hire</option>
                </select>
              </div>
              <div style={{ gridColumn: '1 / -1' }}>
                <label style={labelStyle}>VERIFICATION SOURCE</label>
                <input value={entry.masterVerificationSource} onChange={e => onChange(entry.id, { masterVerificationSource: e.target.value })} placeholder="self-attested, contract…" disabled={effectiveLocked} style={inputStyle} />
              </div>
            </div>

            {entry.masterOwnershipType === 'CO_OWNED' && (
              <div style={{ marginTop: 12 }}>
                <label style={labelStyle}>CO-OWNER SPLITS</label>
                {entry.masterOwnershipSplits.map((split, idx) => (
                  <div key={idx} style={{ display: 'flex', gap: 8, marginBottom: 6, alignItems: 'center' }}>
                    <input value={split.owner} onChange={e => { const splits = entry.masterOwnershipSplits.map((s, i) => i === idx ? { ...s, owner: e.target.value } : s); onChange(entry.id, { masterOwnershipSplits: splits }) }} placeholder="Owner name" disabled={effectiveLocked} style={{ ...inputStyle, flex: 2 }} />
                    <input value={split.pct} onChange={e => { const splits = entry.masterOwnershipSplits.map((s, i) => i === idx ? { ...s, pct: e.target.value } : s); onChange(entry.id, { masterOwnershipSplits: splits }) }} placeholder="%" disabled={effectiveLocked} style={{ ...inputStyle, flex: 1, textAlign: 'right' as const }} />
                    <button onClick={() => { const splits = entry.masterOwnershipSplits.filter((_, i) => i !== idx); onChange(entry.id, { masterOwnershipSplits: splits }) }} disabled={effectiveLocked} style={{ background: 'transparent', border: '0.5px solid var(--border-2)', color: 'var(--text-2)', borderRadius: 6, padding: '4px 8px', fontSize: 12 }}>✕</button>
                  </div>
                ))}
                {(() => {
                  const total = entry.masterOwnershipSplits.reduce((sum, s) => sum + (parseFloat(s.pct) || 0), 0)
                  return (
                    <div style={{ display: 'flex', alignItems: 'center', gap: 12 }}>
                      <button onClick={() => onChange(entry.id, { masterOwnershipSplits: [...entry.masterOwnershipSplits, { owner: '', pct: '' }] })} disabled={effectiveLocked} style={{ background: 'transparent', border: '0.5px solid var(--border-2)', color: 'var(--text-2)', borderRadius: 6, padding: '4px 10px', fontSize: 12 }}>+ Add owner</button>
                      {entry.masterOwnershipSplits.length > 0 && (
                        <span style={{ fontSize: 11, color: Math.abs(total - 100) < 0.01 ? 'var(--pass-fg)' : 'var(--high-fg)' }}>
                          Total: {total.toFixed(1)}% {Math.abs(total - 100) < 0.01 ? '✓' : '(must equal 100)'}
                        </span>
                      )}
                    </div>
                  )
                })()}
              </div>
            )}
          </div>

          {entry.uploadError && entry.status === 'inspected' && (
            <div style={{ color: 'var(--high-fg)', fontSize: 12, marginTop: 12 }}>Queue failed: {entry.uploadError}</div>
          )}
          {saveError && isEditing && (
            <div style={{ color: 'var(--high-fg)', fontSize: 12, marginTop: 12 }}>Save failed: {saveError}</div>
          )}

          <div style={{ marginTop: 14, display: 'flex', gap: 10, alignItems: 'center' }}>
            <button
              onClick={() => onQueue(entry.id)}
              disabled={!canQueue}
              style={{
                background: canQueue ? 'var(--text)' : 'var(--bg-2)',
                color: canQueue ? 'var(--bg)' : 'var(--text-3)',
                border: canQueue ? 'none' : '0.5px solid var(--border-2)',
                borderRadius: 8, padding: '8px 18px', fontSize: 13, fontWeight: 500,
              }}
            >
              {entry.status === 'queueing' ? 'Queueing…' : 'Queue Track'}
            </button>
          </div>
        </div>
      )}

      {entry.status === 'failed' && (
        <div style={{ marginTop: 12 }}>
          {entry.errorReason && <div style={{ color: 'var(--high-fg)', fontSize: 12, marginBottom: 10 }}>Reason: {entry.errorReason}</div>}
          <button onClick={() => onRetry(entry.id)}
            style={{ background: 'var(--blue)', color: 'var(--bg)', border: 'none', borderRadius: 8, padding: '8px 16px', fontSize: 13, fontWeight: 500 }}>
            Retry
          </button>
        </div>
      )}
    </div>
  )
}

function UploadScreen({ entries, setEntries, onBack }: {
  entries: UploadEntry[]
  setEntries: Dispatch<SetStateAction<UploadEntry[]>>
  onBack: () => void
}) {
  const [dragOver, setDragOver]           = useState(false)
  const [validationErrors, setValidErrors] = useState<string[]>([])
  const fileInputRef = useRef<HTMLInputElement>(null)

  function patchEntry(id: string, patch: Partial<UploadEntry>) {
    setEntries(prev => prev.map(e => e.id === id ? { ...e, ...patch } : e))
  }

  function startInspect(entryId: string, file: File) {
    patchEntry(entryId, { status: 'uploading', uploadProgress: 0, uploadError: null })
    inspectFile(file, pct => setEntries(prev => prev.map(e => e.id === entryId ? { ...e, uploadProgress: pct } : e)))
      .then(result => {
        if (!result.filename) { patchEntry(entryId, { status: 'inspect-failed', uploadError: 'Server did not return a filename' }); return }
        setEntries(prev => prev.map(e => {
          if (e.id !== entryId) return e
          return { ...e, status: 'inspected', uploadProgress: 100, serverFilename: result.filename, detectedTitle: result.detectedTitle, detectedIsrc: result.detectedIsrc, isrcSource: result.detectedIsrc ? 'detected' : null, title: e.title || result.detectedTitle || result.normalizedTitle || stripExt(e.file.name), isrc: e.isrc || (result.detectedIsrc ?? '') }
        }))
      })
      .catch((err: Error) => patchEntry(entryId, { status: 'inspect-failed', uploadError: err.message }))
  }

  function addFiles(fileList: FileList | File[] | null) {
    if (!fileList) return
    const incoming = Array.from(fileList)
    const errors: string[] = []
    const accepted: UploadEntry[] = []
    const existingNames = new Set(entries.map(e => e.file.name))
    let runningBytes = entries.reduce((sum, e) => sum + e.file.size, 0)

    for (const file of incoming) {
      if (!isAllowedFile(file)) { errors.push(`${file.name}: only WAV and MP3 are accepted.`); continue }
      if (existingNames.has(file.name)) { errors.push(`${file.name}: already in batch.`); continue }
      if (runningBytes + file.size > MAX_BATCH_BYTES) { errors.push(`${file.name}: would exceed 100 MB limit.`); continue }
      existingNames.add(file.name); runningBytes += file.size
      accepted.push({
        id: newEntryId(), file, status: 'pending', uploadProgress: 0, uploadError: null,
        serverFilename: null, detectedTitle: null, detectedIsrc: null, isrcSource: null,
        title: '', artistName: '', isrc: '', ascapWorkId: '', writerName: '', publisherName: '', proAffiliation: '',
        masterOwnedBy: '', masterOwnershipType: '', masterVerificationSource: '', masterOwnershipSplits: [],
        trackId: null, errorReason: null,
      })
    }

    setValidErrors(errors)
    if (accepted.length > 0) {
      setEntries(prev => [...prev, ...accepted])
      for (const entry of accepted) startInspect(entry.id, entry.file)
    }
  }

  function removeEntry(id: string) { setEntries(prev => prev.filter(e => e.id !== id)) }
  function deleteEntry(id: string) {
    const entry = entries.find(e => e.id === id)
    if (entry?.trackId) fetch(`${API_BASE}/api/tracks/${entry.trackId}`, { method: 'DELETE' }).catch(() => {})
    removeEntry(id)
  }

  function queueOne(id: string) {
    const entry = entries.find(e => e.id === id)
    if (!entry || entry.status !== 'inspected' || !entry.serverFilename || !entry.title.trim() || !ISRC_REGEX.test(entry.isrc)) {
      patchEntry(id, { uploadError: 'Cannot queue: missing required fields' }); return
    }
    patchEntry(id, { status: 'queueing', uploadError: null })
    fetch(`${API_BASE}/api/tracks/upload`, {
      method: 'POST', headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ tracks: [{ filename: entry.serverFilename, title: entry.title.trim(), artistName: entry.artistName.trim() || undefined, isrc: entry.isrc.trim().toUpperCase(), ascapWorkId: entry.ascapWorkId.trim() || undefined, writerName: entry.writerName.trim() || undefined, publisherName: entry.publisherName.trim() || undefined, proAffiliation: entry.proAffiliation.trim() || undefined, masterOwnedBy: entry.masterOwnedBy.trim() || undefined, masterOwnershipType: entry.masterOwnershipType || undefined, masterVerificationSource: entry.masterVerificationSource.trim() || undefined, masterOwnershipSplits: entry.masterOwnershipSplits.length > 0 ? entry.masterOwnershipSplits : undefined }] }),
    })
      .then(async r => {
        const data = (await r.json().catch(() => ({}))) as { tracks?: Array<{ id: string; status: string; error?: string }>; error?: string }
        if (!r.ok) throw new Error(data.error ?? `HTTP ${r.status}`)
        const created = data.tracks?.[0]
        if (!created || created.status === 'error') throw new Error(created?.error ?? 'Backend rejected track')
        patchEntry(id, { status: 'queued', trackId: created.id, uploadError: null })
      })
      .catch((err: Error) => patchEntry(id, { status: 'inspected', uploadError: err.message }))
  }

  function retryOne(id: string) {
    const entry = entries.find(e => e.id === id)
    if (!entry?.trackId) return
    patchEntry(id, { status: 'queued', errorReason: null })
    fetch(`${API_BASE}/api/tracks/${entry.trackId}/retry`, { method: 'POST' })
      .then(async r => { if (!r.ok) { const d = (await r.json().catch(() => ({}))) as { error?: string }; throw new Error(d.error ?? `HTTP ${r.status}`) } })
      .catch((err: Error) => patchEntry(id, { status: 'failed', errorReason: err.message }))
  }

  const totalBytes = entries.reduce((sum, e) => sum + e.file.size, 0)

  return (
    <div style={{ background: 'var(--bg-3)', minHeight: '100vh' }}>
      <Nav
        left={<BackButton label="Brief" onClick={onBack} />}
        right={<span style={{ fontSize: 12, color: 'var(--text-3)' }}>WAV / MP3 · 100 MB max · {formatBytes(totalBytes)} used</span>}
      />
      <div style={{ padding: '20px 16px' }}>
        <p style={{ fontSize: 18, fontWeight: 500, margin: '0 0 4px', color: 'var(--text)' }}>Add Tracks</p>
        <p style={{ color: 'var(--text-2)', fontSize: 13, marginBottom: 20 }}>
          Drop files to inspect ID3 tags, fill rights metadata, and queue for analysis.
        </p>

        <div
          onDragOver={e => { e.preventDefault(); setDragOver(true) }}
          onDragLeave={() => setDragOver(false)}
          onDrop={e => { e.preventDefault(); setDragOver(false); addFiles(e.dataTransfer.files) }}
          onClick={() => fileInputRef.current?.click()}
          style={{
            border: `1.5px dashed ${dragOver ? 'var(--text)' : 'var(--border-2)'}`,
            background: dragOver ? 'var(--bg-2)' : 'var(--bg)',
            borderRadius: 12, padding: '36px 20px', textAlign: 'center', cursor: 'pointer',
          }}
        >
          <div style={{ color: 'var(--text)', fontWeight: 500, fontSize: 15, marginBottom: 4 }}>
            Drop files here or click to browse
          </div>
          <div style={{ color: 'var(--text-2)', fontSize: 13 }}>WAV / MP3 accepted</div>
          <input ref={fileInputRef} type="file" multiple accept=".wav,.mp3,audio/wav,audio/mpeg,audio/mp3" onChange={e => { addFiles(e.target.files); if (fileInputRef.current) fileInputRef.current.value = '' }} style={{ display: 'none' }} />
        </div>

        {validationErrors.length > 0 && (
          <div style={{ background: 'var(--high-bg)', border: '0.5px solid var(--high-fg)', borderRadius: 10, padding: 14, marginTop: 16, color: 'var(--high-fg)', fontSize: 13 }}>
            {validationErrors.map((msg, i) => <div key={i}>{msg}</div>)}
          </div>
        )}

        <div style={{ marginTop: 20 }}>
          {entries.map(entry => (
            <UploadEntryRow key={entry.id} entry={entry} onChange={patchEntry} onRemove={removeEntry} onQueue={queueOne} onRetry={retryOne} onDelete={deleteEntry} />
          ))}
        </div>
      </div>
    </div>
  )
}

// ─── Rights evaluation screen (re-skinned) ────────────────────────────────────

function RightsTrackCard({ result, expanded, onToggle }: { result: RightsTrackResult; expanded: boolean; onToggle: () => void }) {
  const style = RIGHTS_STATE_STYLES[result.evaluation.rights_state]
  const pct = Math.round(result.evaluation.confidence_score * 100)

  return (
    <div onClick={onToggle} style={{
      background: 'var(--bg)', borderRadius: 12, padding: 20, marginBottom: 8,
      cursor: 'pointer', border: expanded ? '0.5px solid var(--blue)' : '0.5px solid var(--border)',
    }}>
      <div style={{ display: 'flex', alignItems: 'center', gap: 14 }}>
        <div style={{ flex: 1 }}>
          <div style={{ display: 'flex', alignItems: 'center', gap: 8, flexWrap: 'wrap' }}>
            <span style={{ color: 'var(--text)', fontWeight: 600, fontSize: 15 }}>{result.title}</span>
            <Badge label={style.label} bg={style.bg} fg={style.fg} />
          </div>
          {result.artistName && <div style={{ color: 'var(--text-2)', fontSize: 13, marginTop: 2 }}>{result.artistName}</div>}
          <div style={{ color: 'var(--text-3)', fontFamily: 'var(--font-mono)', fontSize: 12, marginTop: 2 }}>{result.isrc}</div>
        </div>
        <div style={{ textAlign: 'right', flexShrink: 0 }}>
          <div style={{ fontSize: 32, fontWeight: 900, color: 'var(--text)', lineHeight: 1, fontVariantNumeric: 'tabular-nums' }}>{pct}%</div>
          <div style={{ color: 'var(--text-3)', fontSize: 11, marginTop: 2 }}>CONFIDENCE</div>
        </div>
      </div>

      {expanded && (
        <div style={{ borderTop: '0.5px solid var(--border)', marginTop: 16, paddingTop: 16 }}>
          <p style={{ color: 'var(--text-2)', fontSize: 14, lineHeight: 1.6, margin: '0 0 16px' }}>{result.evaluation.clearance_summary}</p>
          {result.evaluation.blockers.length > 0 && (
            <div style={{ marginBottom: 16 }}>
              <div style={{ color: 'var(--text-3)', fontSize: 12, marginBottom: 6 }}>BLOCKERS</div>
              {result.evaluation.blockers.map(b => (
                <div key={b} style={{ background: 'var(--high-bg)', border: '0.5px solid var(--high-fg)', borderRadius: 6, padding: '6px 10px', color: 'var(--high-fg)', fontSize: 12, fontFamily: 'var(--font-mono)', marginBottom: 4 }}>{b}</div>
              ))}
            </div>
          )}
          <div style={{ marginBottom: 16 }}>
            <div style={{ color: 'var(--text-3)', fontSize: 12, marginBottom: 6 }}>TRANSITION TRACE</div>
            {result.evaluation.transition_trace.map((t, i) => (
              <div key={i} style={{ display: 'flex', alignItems: 'center', gap: 8, padding: '5px 0', borderBottom: i < result.evaluation.transition_trace.length - 1 ? '0.5px solid var(--border)' : 'none', opacity: t.triggered ? 1 : 0.35 }}>
                <span style={{ width: 8, height: 8, borderRadius: '50%', background: t.triggered ? 'var(--pass-fg)' : 'var(--text-3)', flexShrink: 0, display: 'inline-block' }} />
                <span style={{ color: 'var(--text-2)', fontSize: 12, flex: 1 }}>{t.rule}</span>
                {t.triggered && <span style={{ color: 'var(--text-3)', fontSize: 11 }}>{t.from ?? '∅'} → {t.to}</span>}
              </div>
            ))}
          </div>
          <div>
            <div style={{ color: 'var(--text-3)', fontSize: 12 }}>AUDIT HASH</div>
            <div style={{ color: 'var(--text-3)', fontFamily: 'var(--font-mono)', fontSize: 11, wordBreak: 'break-all', marginTop: 4, lineHeight: 1.5 }}>{result.evaluation.audit_hash.hash}</div>
          </div>
        </div>
      )}
    </div>
  )
}

function RightsScreen({ onBack }: { onBack: () => void }) {
  const [data, setData]   = useState<RightsResponse | null>(null)
  const [loading, setLoading] = useState(false)
  const [error, setError]   = useState<string | null>(null)
  const [expanded, setExpanded] = useState<string | null>(null)

  useEffect(() => {
    setLoading(true)
    fetch(`${API_BASE}/api/rights/evaluate`)
      .then(r => { if (!r.ok) throw new Error(`HTTP ${r.status}`); return r.json() as Promise<RightsResponse> })
      .then(setData)
      .catch((e: Error) => setError(e.message))
      .finally(() => setLoading(false))
  }, [])

  const stateOrder: RightsState[] = ['CLEAR', 'PARTIALLY_CLEAR', 'UNVERIFIED', 'INGESTED', 'BLOCKED']

  return (
    <div style={{ background: 'var(--bg-3)', minHeight: '100vh' }}>
      <Nav left={<BackButton label="Brief" onClick={onBack} />} />
      <div style={{ padding: '20px 16px' }}>
        <p style={{ fontSize: 18, fontWeight: 500, margin: '0 0 4px', color: 'var(--text)' }}>Rights Evaluation</p>
        <p style={{ color: 'var(--text-2)', fontSize: 13, marginBottom: 20 }}>
          Deterministic rights state machine — engine v{data?.engine_version ?? '…'}
        </p>
        {data && (
          <div style={{ display: 'flex', gap: 8, flexWrap: 'wrap', marginBottom: 20 }}>
            {stateOrder.map(state => {
              const count = data.state_summary[state] ?? 0
              if (!count) return null
              const s = RIGHTS_STATE_STYLES[state]
              return <Badge key={state} label={`${s.label} · ${count}`} bg={s.bg} fg={s.fg} />
            })}
          </div>
        )}
        {loading && <div style={{ color: 'var(--text-3)', textAlign: 'center', padding: '60px 0' }}>Evaluating tracks…</div>}
        {error && <div style={{ background: 'var(--high-bg)', border: '0.5px solid var(--high-fg)', borderRadius: 10, padding: 20, color: 'var(--high-fg)', textAlign: 'center' }}><strong>Error:</strong> {error}</div>}
        {data && data.tracks.map(result => (
          <RightsTrackCard key={result.audio_id} result={result} expanded={expanded === result.audio_id} onToggle={() => setExpanded(prev => prev === result.audio_id ? null : result.audio_id)} />
        ))}
      </div>
    </div>
  )
}

// ─── Determinism verification screen (re-skinned) ────────────────────────────

interface DeterminismReport { hashesMatch: boolean; rankingStable: boolean; runCount: number; verifiedAt: string; [key: string]: unknown }

function DeterminismVerificationView({ onBack }: { onBack: () => void }) {
  const [report, setReport] = useState<DeterminismReport | null>(null)
  const [loading, setLoading] = useState(false)
  const [error, setError]   = useState<string | null>(null)

  useEffect(() => {
    setLoading(true)
    fetch(`${API_BASE}/api/determinism-report`)
      .then(r => r.json() as Promise<DeterminismReport | { error: string }>)
      .then(data => { if ('error' in data) throw new Error((data as any).error); setReport(data as DeterminismReport) })
      .catch((e: Error) => setError(e.message))
      .finally(() => setLoading(false))
  }, [])

  return (
    <div style={{ background: 'var(--bg-3)', minHeight: '100vh' }}>
      <Nav left={<BackButton label="Brief" onClick={onBack} />} />
      <div style={{ padding: '20px 16px' }}>
        <p style={{ fontSize: 18, fontWeight: 500, margin: '0 0 4px', color: 'var(--text)' }}>Determinism Verification</p>
        <p style={{ color: 'var(--text-2)', fontSize: 13, marginBottom: 20 }}>Cryptographic proof that scoring output is identical across every run.</p>
        {loading && <div style={{ color: 'var(--text-3)', textAlign: 'center', padding: '60px 0' }}>Loading report…</div>}
        {error && <div style={{ background: 'var(--high-bg)', border: '0.5px solid var(--high-fg)', borderRadius: 10, padding: 20, color: 'var(--high-fg)' }}><strong>Report unavailable:</strong> {error}</div>}
        {report && (
          <div style={{ background: 'var(--bg)', borderRadius: 12, padding: 24, border: '0.5px solid var(--border)' }}>
            <div style={{ display: 'grid', gridTemplateColumns: '1fr 1fr', gap: 16, marginBottom: 20 }}>
              <Stat label="Hashes Match" value={<span style={{ fontSize: 24, color: report.hashesMatch ? 'var(--pass-fg)' : 'var(--high-fg)' }}>{report.hashesMatch ? '✓' : '✗'}</span>} />
              <Stat label="Ranking Stable" value={<span style={{ fontSize: 24, color: report.rankingStable ? 'var(--pass-fg)' : 'var(--high-fg)' }}>{report.rankingStable ? '✓' : '✗'}</span>} />
              <Stat label="Run Count" value={<span style={{ fontSize: 24, fontWeight: 700 }}>{report.runCount ?? '—'}</span>} />
              <Stat label="Verified At" value={<span style={{ fontSize: 12, fontFamily: 'var(--font-mono)' }}>{report.verifiedAt ? new Date(report.verifiedAt).toLocaleString() : '—'}</span>} />
            </div>
            {!report.hashesMatch && (
              <div style={{ background: 'var(--high-bg)', border: '0.5px solid var(--high-fg)', borderRadius: 8, padding: '12px 16px', color: 'var(--high-fg)', fontSize: 13 }}>
                DETERMINISM VIOLATION — contact system administrator
              </div>
            )}
          </div>
        )}
      </div>
    </div>
  )
}

// ─── Catalog analytics screen (re-skinned) ────────────────────────────────────

interface CatalogTrack { id: string; title: string; artistName: string | null; isrc: string; trackStatus: string; ascapWorkId: string | null; isOneStop: boolean | null }

function CatalogAnalyticsDashboard({ onBack }: { onBack: () => void }) {
  const [tracks, setTracks] = useState<CatalogTrack[] | null>(null)
  const [loading, setLoading] = useState(false)
  const [error, setError]   = useState<string | null>(null)

  useEffect(() => {
    setLoading(true)
    fetch(`${API_BASE}/api/tracks`)
      .then(r => { if (!r.ok) throw new Error(`HTTP ${r.status}`); return r.json() as Promise<{ tracks: CatalogTrack[] }> })
      .then(d => setTracks(d.tracks))
      .catch((e: Error) => setError(e.message))
      .finally(() => setLoading(false))
  }, [])

  const STATUS_MAP: Record<string, { bg: string; fg: string }> = {
    uploaded:  { bg: 'var(--neutral-bg)', fg: 'var(--neutral-fg)' },
    analyzing: { bg: 'var(--mod-bg)',     fg: 'var(--mod-fg)' },
    analyzed:  { bg: 'var(--pass-bg)',    fg: 'var(--pass-fg)' },
    failed:    { bg: 'var(--high-bg)',    fg: 'var(--high-fg)' },
    queued:    { bg: '#dbeafe',           fg: '#1e40af' },
  }

  const statusGroups = tracks
    ? Object.entries(tracks.reduce<Record<string, number>>((acc, t) => { acc[t.trackStatus] = (acc[t.trackStatus] ?? 0) + 1; return acc }, {}))
    : []

  return (
    <div style={{ background: 'var(--bg-3)', minHeight: '100vh' }}>
      <Nav left={<BackButton label="Brief" onClick={onBack} />} />
      <div style={{ padding: '20px 16px' }}>
        <p style={{ fontSize: 18, fontWeight: 500, margin: '0 0 4px', color: 'var(--text)' }}>Catalog Analytics</p>
        <p style={{ color: 'var(--text-2)', fontSize: 13, marginBottom: 20 }}>Track inventory and analysis status across your catalog.</p>
        {loading && <div style={{ color: 'var(--text-3)', textAlign: 'center', padding: '60px 0' }}>Loading…</div>}
        {error && <div style={{ background: 'var(--high-bg)', border: '0.5px solid var(--high-fg)', borderRadius: 10, padding: 20, color: 'var(--high-fg)', textAlign: 'center' }}><strong>Error:</strong> {error}</div>}
        {tracks && (
          <>
            <div style={{ display: 'flex', gap: 10, flexWrap: 'wrap', marginBottom: 20 }}>
              <div style={{ background: 'var(--bg)', border: '0.5px solid var(--border)', borderRadius: 10, padding: '14px 20px' }}>
                <div style={{ color: 'var(--text-3)', fontSize: 11, textTransform: 'uppercase', letterSpacing: '0.06em', marginBottom: 4 }}>Total</div>
                <div style={{ color: 'var(--text)', fontSize: 28, fontWeight: 700 }}>{tracks.length}</div>
              </div>
              {statusGroups.map(([status, count]) => {
                const s = STATUS_MAP[status] ?? { bg: 'var(--neutral-bg)', fg: 'var(--neutral-fg)' }
                return (
                  <div key={status} style={{ background: s.bg, borderRadius: 10, padding: '14px 20px' }}>
                    <div style={{ color: s.fg, fontSize: 11, textTransform: 'uppercase', letterSpacing: '0.06em', marginBottom: 4, opacity: 0.85 }}>{status}</div>
                    <div style={{ color: s.fg, fontSize: 28, fontWeight: 700 }}>{count}</div>
                  </div>
                )
              })}
            </div>
            <div>
              {tracks.map(track => {
                const s = STATUS_MAP[track.trackStatus] ?? { bg: 'var(--neutral-bg)', fg: 'var(--neutral-fg)' }
                return (
                  <div key={track.id} style={{ background: 'var(--bg)', borderRadius: 10, padding: '14px 18px', marginBottom: 6, display: 'flex', alignItems: 'center', gap: 12, border: '0.5px solid var(--border)' }}>
                    <div style={{ flex: 1 }}>
                      <div style={{ color: 'var(--text)', fontWeight: 500, fontSize: 14 }}>{track.title}</div>
                      {track.artistName && <div style={{ color: 'var(--text-2)', fontSize: 12, marginTop: 2 }}>{track.artistName}</div>}
                      <div style={{ color: 'var(--text-3)', fontFamily: 'var(--font-mono)', fontSize: 11, marginTop: 2 }}>{track.isrc}</div>
                    </div>
                    {track.isOneStop && <Badge label="ONE-STOP" bg="var(--pass-bg)" fg="var(--pass-fg)" />}
                    <Badge label={track.trackStatus} bg={s.bg} fg={s.fg} />
                  </div>
                )
              })}
            </div>
          </>
        )}
      </div>
    </div>
  )
}

// ─── Root app ──────────────────────────────────────────────────────────────────

export default function App() {
  const [view, setView] = useState<View>('brief')

  // Scene match state
  const [sceneData, setSceneData]       = useState<SceneResponse | null>(null)
  const [sceneLoading, setSceneLoading] = useState(false)
  const [sceneError, setSceneError]     = useState<string | null>(null)
  const [selectedMatch, setSelectedMatch] = useState<SceneMatch | null>(null)

  // All-tracks state
  const [tracks, setTracks]   = useState<RankedTrack[] | null>(null)
  const [loading, setLoading] = useState(false)
  const [error, setError]     = useState<string | null>(null)
  const [expanded, setExpanded] = useState<string | null>(null)
  const [banner, setBanner]   = useState<BannerState>(null)
  const prevHashes = useRef<Record<string, string>>({})
  const bannerTimer = useRef<ReturnType<typeof setTimeout> | null>(null)

  // Upload state — held at App level so polling continues across nav
  const [uploadEntries, setUploadEntries] = useState<UploadEntry[]>([])
  const hasInFlight = uploadEntries.some(e => isInFlight(e.status))

  // Upload polling
  useEffect(() => {
    if (!hasInFlight) return
    let cancelled = false
    const tick = () => {
      fetch(`${API_BASE}/api/tracks`)
        .then(r => { if (!r.ok) throw new Error(`HTTP ${r.status}`); return r.json() as Promise<{ tracks: Array<{ id: string; trackStatus: string; errorReason: string | null }> }> })
        .then(data => {
          if (cancelled) return
          const byId = new Map(data.tracks.map(t => [t.id, t]))
          setUploadEntries(prev => prev.map(e => {
            if (!e.trackId) return e
            const t = byId.get(e.trackId)
            if (!t) return e
            const newStatus: UploadStatus = t.trackStatus === 'analyzed' ? 'analyzed' : t.trackStatus === 'failed' ? 'failed' : t.trackStatus === 'analyzing' ? 'analyzing' : 'queued'
            if (e.status === newStatus && e.errorReason === t.errorReason) return e
            return { ...e, status: newStatus, errorReason: t.errorReason }
          }))
        })
        .catch(() => { /* retry next tick */ })
    }
    tick()
    const interval = setInterval(tick, POLL_INTERVAL_MS)
    return () => { cancelled = true; clearInterval(interval) }
  }, [hasInFlight])

  function showBanner(state: BannerState) {
    setBanner(state)
    if (bannerTimer.current) clearTimeout(bannerTimer.current)
    bannerTimer.current = setTimeout(() => setBanner(null), 4000)
  }

  function loadScores(isRerun = false) {
    setLoading(true); setError(null)
    fetch(`${API_BASE}/api/scores`)
      .then(r => { if (!r.ok) throw new Error(`HTTP ${r.status}`); return r.json() as Promise<ApiResponse> })
      .then(data => {
        const newTracks = data.rankedTracks
        if (isRerun && Object.keys(prevHashes.current).length > 0) {
          const violation = newTracks.some(t => prevHashes.current[t.trackId] !== undefined && prevHashes.current[t.trackId] !== t.inputHash)
          showBanner(violation ? 'violation' : 'ok')
        }
        const hashMap: Record<string, string> = {}
        newTracks.forEach(t => { hashMap[t.trackId] = t.inputHash })
        prevHashes.current = hashMap
        setTracks(newTracks)
      })
      .catch((err: Error) => setError(err.message))
      .finally(() => setLoading(false))
  }

  useEffect(() => {
    if (view === 'all' && tracks === null) loadScores(false)
    // eslint-disable-next-line react-hooks/exhaustive-deps
  }, [view])

  function handleSceneSelect(sceneId: string, sceneLabel: string) {
    setSelectedMatch(null); setSceneData(null); setSceneError(null); setSceneLoading(true); setView('results')
    const trialToken = getStoredTrialToken()
    const headers: Record<string, string> = {}
    if (trialToken) headers['x-trial-token'] = trialToken
    fetch(`${API_BASE}/api/scores/scene/${sceneId}`, { headers })
      .then(async r => {
        if (r.status === 401 || r.status === 403) {
          const body = await r.json().catch(() => ({})) as { upgradeRequired?: boolean; error?: string }
          if (body.upgradeRequired) { setSceneLoading(false); setView('pricing'); return null }
          throw new Error(body.error ?? `HTTP ${r.status}`)
        }
        if (!r.ok) throw new Error(`HTTP ${r.status}`)
        return r.json() as Promise<SceneResponse>
      })
      .then(data => { if (!data) return; setSceneData({ ...data, sceneLabel: data.sceneLabel || sceneLabel }) })
      .catch((err: Error) => setSceneError(err.message))
      .finally(() => setSceneLoading(false))
  }

  return (
    <>
      <style>{GLOBAL_STYLES}</style>

      {/* Determinism violation banner */}
      {banner && (
        <div style={{
          position: 'fixed', top: 0, left: 0, right: 0, zIndex: 100,
          background: banner === 'ok' ? 'var(--pass-bg)' : 'var(--high-bg)',
          color: banner === 'ok' ? 'var(--pass-fg)' : 'var(--high-fg)',
          textAlign: 'center', padding: '12px 20px', fontWeight: 500, fontSize: 14,
          borderBottom: `0.5px solid ${banner === 'ok' ? 'var(--pass-fg)' : 'var(--high-fg)'}`,
        }}>
          {banner === 'ok'
            ? 'All hashes verified — output is deterministic'
            : 'DETERMINISM VIOLATION — contact system administrator'}
        </div>
      )}

      {/* ── Screen routing ── */}
      {view === 'brief' && (
        <BriefIntakeScreen
          onRunScene={handleSceneSelect}
          onUpload={() => setView('upload')}
          onComposer={() => setView('composer')}
          onViewAll={() => setView('all')}
          onRoi={() => setView('roi')}
          onPricing={() => setView('pricing')}
          onRights={() => setView('rights')}
          onAnalytics={() => setView('analytics')}
        />
      )}

      {view === 'results' && (
        <ResultsScreen
          sceneData={sceneData}
          loading={sceneLoading}
          error={sceneError}
          onBack={() => setView('brief')}
          onSelectMatch={match => { setSelectedMatch(match); setView('packet') }}
          onExport={() => { /* PDF export — future */ }}
        />
      )}

      {view === 'packet' && selectedMatch && sceneData && (
        <PacketScreen
          match={selectedMatch}
          rankedMatches={sceneData.rankedMatches}
          sceneLabel={sceneData.sceneLabel}
          onBack={() => setView('results')}
        />
      )}

      {view === 'composer' && (
        <ComposerReportScreen onBack={() => setView('brief')} />
      )}

      {view === 'upload' && (
        <UploadScreen entries={uploadEntries} setEntries={setUploadEntries} onBack={() => setView('brief')} />
      )}

      {view === 'all' && (
        <div style={{ background: 'var(--bg-3)', minHeight: '100vh' }}>
          <Nav
            left={<BackButton label="Brief" onClick={() => setView('brief')} />}
            right={
              <button
                onClick={() => loadScores(true)} disabled={loading}
                style={{ background: 'var(--text)', color: 'var(--bg)', border: 'none', borderRadius: 8, padding: '8px 16px', fontSize: 13, fontWeight: 500, opacity: loading ? 0.6 : 1 }}>
                {loading ? 'Loading…' : 'Run Again'}
              </button>
            }
          />
          <div style={{ padding: '20px 16px' }}>
            <p style={{ fontSize: 18, fontWeight: 500, margin: '0 0 20px', color: 'var(--text)' }}>All Tracks</p>
            {loading && !tracks && <div style={{ color: 'var(--text-3)', textAlign: 'center', padding: '60px 0' }}>Fetching tracks…</div>}
            {error && <div style={{ background: 'var(--high-bg)', border: '0.5px solid var(--high-fg)', borderRadius: 10, padding: 20, color: 'var(--high-fg)', textAlign: 'center' }}><strong>Error:</strong> {error}</div>}
            {tracks && tracks.map(track => (
              <AllTrackCard key={track.trackId} track={track} expanded={expanded === track.trackId} onToggle={() => setExpanded(prev => prev === track.trackId ? null : track.trackId)} />
            ))}
          </div>
        </div>
      )}

      {view === 'rights' && <RightsScreen onBack={() => setView('brief')} />}
      {view === 'analytics' && <CatalogAnalyticsDashboard onBack={() => setView('brief')} />}
      {view === 'verification' && <DeterminismVerificationView onBack={() => setView('brief')} />}
      {view === 'roi' && <RoiCalculator onBack={() => setView('brief')} />}
      {view === 'pricing' && <PricingPage onBack={() => setView('brief')} />}
    </>
  )
}
