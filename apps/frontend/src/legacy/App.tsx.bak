  UNVERIFIED:      { bg: '#dbeafe',           fg: '#1e40af',          label: 'UNVERIFIED' },
  INGESTED:        { bg: 'var(--neutral-bg)', fg: 'var(--text-2)',    label: 'INGESTED' },
