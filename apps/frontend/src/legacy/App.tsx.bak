// ─── Design helpers ───────────────────────────────────────────────────────────

/** Map existing confidence label → PASS tier */
function passLabel(score: number): { label: string; bg: string; fg: string } {
  if (score >= 80) return { label: 'PASS_STRONG', bg: 'var(--pass-bg)',     fg: 'var(--pass-fg)' }
  if (score >= 60) return { label: 'PASS_SOFT',   bg: 'var(--soft-bg)',     fg: 'var(--soft-fg)' }
  return               { label: 'REVIEW',          bg: 'var(--review-bg)',   fg: 'var(--review-fg)' }
}

function fragmentationLabel(isOneStop: boolean, score: number): { label: string; bg: string; fg: string } {
  if (isOneStop && score >= 75)
    return { label: 'LOW fragmentation',      bg: 'var(--neutral-bg)', fg: 'var(--neutral-fg)' }
  if (score >= 55)
    return { label: 'MODERATE fragmentation', bg: 'var(--mod-bg)',     fg: 'var(--mod-fg)' }
  return   { label: 'HIGH fragmentation',     bg: 'var(--high-bg)',    fg: 'var(--high-fg)' }
}

function clearanceEstimate(isOneStop: boolean, score: number): string {
  if (isOneStop && score >= 80) return '48–72 hrs*'
  if (isOneStop && score >= 60) return '3–7 days*'
  if (!isOneStop && score >= 70) return '2–4 weeks*'
  return 'Est. by publisher'
}

type Risk = 'LOW' | 'MEDIUM' | 'HIGH' | 'NONE'

function cutRisk(bd: Breakdown): Risk {
  return bd.rights >= 50 ? 'LOW' : bd.rights >= 30 ? 'MEDIUM' : 'HIGH'
}
function overexposureRisk(score: number): Risk {
  return score >= 80 ? 'LOW' : score >= 60 ? 'MEDIUM' : 'HIGH'
}
function driftRisk(bd: Breakdown): Risk {
  return bd.metadata >= 16 ? 'NONE' : bd.metadata >= 10 ? 'LOW' : 'MEDIUM'
}

function riskColor(r: Risk): string {
  switch (r) {
    case 'NONE': return 'var(--text-2)'
    case 'LOW':  return 'var(--text-2)'
    case 'MEDIUM': return 'var(--mod-fg)'
    case 'HIGH':   return 'var(--high-fg)'
  }
}

interface UsageWindow {
  label: string
  icon: string
  status: 'Cleared' | 'Review req.'
  bg: string
  fg: string
  iconColor: string
}

function usageWindows(isOneStop: boolean, score: number): UsageWindow[] {
  const cleared = { bg: 'var(--pass-bg)', fg: 'var(--pass-fg)', iconColor: '#3b6d11' }
  const review  = { bg: 'var(--mod-bg)',  fg: 'var(--mod-fg)',  iconColor: '#854f0b' }
  const tv    = score >= 55
  const film  = score >= 60
  const ad    = isOneStop && score >= 65
  const trailer = isOneStop && score >= 80
  return [
    { label: 'TV / stream', icon: '📺', status: tv ? 'Cleared' : 'Review req.',    ...(tv    ? cleared : review) },
    { label: 'Film',        icon: '🎬', status: film ? 'Cleared' : 'Review req.',  ...(film  ? cleared : review) },
    { label: 'Ad',          icon: '📣', status: ad ? 'Cleared' : 'Review req.',    ...(ad    ? cleared : review) },
    { label: 'Trailer',     icon: '⚡', status: trailer ? 'Cleared' : 'Review req.',  ...(trailer ? cleared : review) },
  ]
}

function barColor(score: number): string {
  if (score >= 75) return '#639922'
  if (score >= 55) return '#ef9f27'
  return '#e24b4a'
}

// ─── Upload helpers ───────────────────────────────────────────────────────────

function fileExt(name: string): string {
  const m = name.match(/\.[^.]+$/)
  return m ? m[0].toLowerCase() : ''
}
function isAllowedFile(file: File): boolean {
  return (ALLOWED_EXTENSIONS as readonly string[]).includes(fileExt(file.name))
}
function formatBytes(bytes: number): string {
  if (bytes < 1024) return `${bytes} B`
  if (bytes < 1024 * 1024) return `${(bytes / 1024).toFixed(1)} KB`
  return `${(bytes / 1024 / 1024).toFixed(1)} MB`
}
function stripExt(name: string): string {
  return name.replace(/\.[^.]+$/, '')
}

interface InspectResult {
  filename: string
  originalName: string
  sizeBytes: number
  detectedTitle: string | null
  detectedIsrc: string | null
  normalizedTitle: string | null
}

function inspectFile(file: File, onProgress: (pct: number) => void): Promise<InspectResult> {
  return new Promise((resolve, reject) => {
    const fd = new FormData()
    fd.append('files', file, file.name)
    const xhr = new XMLHttpRequest()
    xhr.open('POST', `${API_BASE}/api/tracks/inspect`)
    xhr.upload.onprogress = (e) => {
      if (e.lengthComputable) onProgress(Math.round((e.loaded / e.total) * 100))
    }
    xhr.onload = () => {
      let data: { files?: InspectResult[]; error?: string } = {}
      try { data = JSON.parse(xhr.responseText) } catch { /* keep empty */ }
      if (xhr.status >= 200 && xhr.status < 300 && Array.isArray(data.files) && data.files[0]) {
        resolve(data.files[0])
      } else {
        reject(new Error(data.error ?? `Upload failed (HTTP ${xhr.status})`))
      }
    }
    xhr.onerror = () => reject(new Error('Network error during upload'))
    xhr.send(fd)
  })
}

const STATUS_BADGES: Record<UploadStatus, { label: string; bg: string; fg: string }> = {
  pending:          { label: 'Waiting…',       bg: 'var(--neutral-bg)', fg: 'var(--text-2)' },
  uploading:        { label: 'Uploading',      bg: 'var(--mod-bg)',     fg: 'var(--mod-fg)' },
  inspected:        { label: 'Ready to queue', bg: '#dbeafe',           fg: '#1e40af' },
  'inspect-failed': { label: 'Upload failed',  bg: 'var(--high-bg)',    fg: 'var(--high-fg)' },
  queueing:         { label: 'Queueing…',      bg: '#dbeafe',           fg: '#1e40af' },
  queued:           { label: 'Queued',         bg: 'var(--mod-bg)',     fg: 'var(--mod-fg)' },
  analyzing:        { label: 'Analyzing',      bg: 'var(--mod-bg)',     fg: 'var(--mod-fg)' },
  analyzed:         { label: 'Analyzed',       bg: 'var(--pass-bg)',    fg: 'var(--pass-fg)' },
  failed:           { label: 'Analysis failed',bg: 'var(--high-bg)',    fg: 'var(--high-fg)' },
}

function isInFlight(status: UploadStatus): boolean {
  return status === 'queued' || status === 'analyzing'
}

function newEntryId(): string {
  if (typeof crypto !== 'undefined' && typeof crypto.randomUUID === 'function') {
    return crypto.randomUUID()
  }
  return `${Date.now()}-${Math.random().toString(36).slice(2)}`
}

