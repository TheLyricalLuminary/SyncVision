# =========================================================
# SyncVision Backend — Environment Variables
# =========================================================
# Copy this file to .env (local dev) or populate Render dashboard (production).
# NEVER commit .env, .env.staging, or .env.production with real values.
# Generate secrets: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# =========================================================

# =========================================================
# APP ENVIRONMENT
# =========================================================
NODE_ENV="development"
# Frontend canonical URL — used for Stripe success/cancel redirects
APP_URL="http://localhost:5173"
# API canonical URL
API_URL="http://localhost:3001"
PORT=3001

# =========================================================
# DATABASE
# =========================================================
# Neon PostgreSQL pooler URL (required)
DATABASE_URL="postgresql://user:password@host-pooler.neon.tech/db?sslmode=require&channel_binding=require"

# =========================================================
# JWT / AUTH
# =========================================================
# 64-byte hex minimum. NEVER use "change_me" or short strings.
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="replace_with_64_byte_hex"
JWT_EXPIRES_IN="7d"

# =========================================================
# STRIPE
# =========================================================
# sk_test_... for dev/staging, sk_live_... for production
STRIPE_SECRET_KEY="sk_test_replace"
# Webhook signing secret from Stripe Dashboard → Webhooks → Signing secret
STRIPE_WEBHOOK_SECRET="whsec_replace"
# Publishable key for frontend checkout initialization
STRIPE_PUBLISHABLE_KEY="pk_test_replace"

# Optional: pre-created Stripe Price IDs. When set, stripe.ts uses these
# instead of inline price_data (recommended for production).
STRIPE_PRICE_STARTER=""
STRIPE_PRICE_PRO=""
STRIPE_PRICE_STUDIO=""
STRIPE_PRICE_ENTERPRISE=""

# =========================================================
# REDIS / BULLMQ
# =========================================================
# redis:// for local, rediss:// for TLS (Render/Upstash in production)
REDIS_URL="redis://localhost:6379"
# Prefix all BullMQ queue keys — prevents cross-environment collisions.
# Use syncvision:local / syncvision:staging / syncvision:prod
QUEUE_PREFIX="syncvision:local"

# =========================================================
# RECONCILIATION + CRON
# =========================================================
# Set false in local dev to avoid hitting Stripe API every 15 min
ENABLE_STRIPE_RECONCILIATION="false"
# Cron interval in minutes (default 15)
STRIPE_RECON_INTERVAL_MINUTES="15"

# =========================================================
# DATABASE FINGERPRINTING
# =========================================================
# Human-readable environment label for audit logs and drift detection
DB_ENVIRONMENT="local-dev"
# 32-byte hex salt — unique per environment, never shared
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
DB_FINGERPRINT_SALT="replace_with_32_byte_hex"

# =========================================================
# SECURITY
# =========================================================
# Set true when behind a reverse proxy (Render, nginx, Cloudflare).
# Required for correct IP detection and HTTPS enforcement.
TRUST_PROXY="false"
# Optional: comma-separated CIDRs or IPs for /api/admin routes
ADMIN_IP_ALLOWLIST=""

# =========================================================
# OBSERVABILITY
# =========================================================
# debug | info | warn | error
LOG_LEVEL="debug"
# Sentry DSN — leave empty to disable error reporting
SENTRY_DSN=""

# =========================================================
# PYTHON / ANALYSIS
# =========================================================
PYTHON_BIN="/usr/bin/python3"
AUDIO_DIR="/path/to/audio"
