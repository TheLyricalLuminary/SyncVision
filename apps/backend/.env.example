# =========================================================
# SyncVision Backend — Environment Variables
# =========================================================
# Copy this file to .env (local dev) or populate Render dashboard (production).
# NEVER commit .env, .env.staging, or .env.production with real values.
# Generate secrets: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
#
# Legend:
#   [REQUIRED] — server aborts on startup if missing
#   [OPTIONAL] — safe to omit; feature disabled or has a default
# =========================================================

# =========================================================
# APP ENVIRONMENT
# =========================================================
NODE_ENV="development"
PORT=3001

# [REQUIRED] Public URL of the frontend — used for:
#   • CORS allowed-origins list
#   • Stripe checkout success/cancel redirects
#   • Must match the browser-visible URL exactly (no trailing slash)
FRONTEND_URL="http://localhost:5174"

# [OPTIONAL] Comma-separated additional allowed CORS origins.
# Use when the frontend is served from a second domain (e.g. custom domain + CDN alias).
EXTRA_ALLOWED_ORIGINS=""

# [OPTIONAL] Legacy alias — some internal references still read APP_URL.
# Set to the same value as FRONTEND_URL in production.
APP_URL="http://localhost:5174"

# [OPTIONAL] API canonical URL — used in generated links where the backend URL is needed
API_URL="http://localhost:3001"

# =========================================================
# DATABASE
# =========================================================
# [REQUIRED] Neon PostgreSQL pooler URL
DATABASE_URL="postgresql://user:password@host-pooler.neon.tech/db?sslmode=require&channel_binding=require"

# =========================================================
# JWT / AUTH
# =========================================================
# [REQUIRED] 64-byte hex minimum. NEVER use "change_me" or short strings.
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="replace_with_64_byte_hex"
# [OPTIONAL] Token lifetime (default: 7d)
JWT_EXPIRES_IN="7d"

# =========================================================
# AUDIO STORAGE
# =========================================================
# [REQUIRED] Absolute path to the directory where uploaded audio files are stored.
# The backend serves this directory at /audio — must be writable by the Node process.
# Example (Render): /opt/render/project/src/audio
AUDIO_STORAGE_PATH="/path/to/audio"

# [REQUIRED] Secret used to sign short-lived audio stream tokens.
# These tokens gate access to /audio/:filename — without this the server refuses to start.
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
AUDIO_TOKEN_SECRET="replace_with_64_byte_hex"

# =========================================================
# STRIPE
# =========================================================
# [OPTIONAL] sk_test_... for dev/staging, sk_live_... for production.
# Stripe routes return 503 when this is absent — everything else still works.
STRIPE_SECRET_KEY="sk_test_replace"
# [OPTIONAL] Webhook signing secret from Stripe Dashboard → Webhooks → Signing secret
STRIPE_WEBHOOK_SECRET="whsec_replace"
# [OPTIONAL] Publishable key for frontend checkout initialization
STRIPE_PUBLISHABLE_KEY="pk_test_replace"

# [OPTIONAL] Pre-created Stripe Price IDs. When set, stripe.ts uses these
# instead of inline price_data (recommended for production).
STRIPE_PRICE_STARTER=""
STRIPE_PRICE_PRO=""
STRIPE_PRICE_STUDIO=""
STRIPE_PRICE_ENTERPRISE=""

# =========================================================
# REDIS / BULLMQ
# =========================================================
# [OPTIONAL] redis:// for local, rediss:// for TLS (Render/Upstash in production).
# When absent: audio analysis queue and webhook worker are skipped; Stripe webhook
# falls back to inline dispatch.
REDIS_URL="redis://localhost:6379"
# [OPTIONAL] Prefix all BullMQ queue keys — prevents cross-environment collisions.
# Use syncvision:local / syncvision:staging / syncvision:prod
QUEUE_PREFIX="syncvision:local"

# =========================================================
# RECONCILIATION + CRON
# =========================================================
# [OPTIONAL] Set false in local dev to avoid hitting Stripe API every 15 min
ENABLE_STRIPE_RECONCILIATION="false"
# [OPTIONAL] Cron interval in minutes (default 15)
STRIPE_RECON_INTERVAL_MINUTES="15"

# =========================================================
# DATABASE FINGERPRINTING
# =========================================================
# [OPTIONAL] Human-readable environment label for audit logs and drift detection
DB_ENVIRONMENT="local-dev"
# [OPTIONAL] 32-byte hex salt — unique per environment, never shared
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
DB_FINGERPRINT_SALT="replace_with_32_byte_hex"

# =========================================================
# SECURITY
# =========================================================
# [OPTIONAL] Set true when behind a reverse proxy (Render, nginx, Cloudflare).
# Required for correct IP detection and HTTPS enforcement.
TRUST_PROXY="false"
# [OPTIONAL] Comma-separated CIDRs or IPs allowed to call /api/admin routes
ADMIN_IP_ALLOWLIST=""

# =========================================================
# DIAGNOSTICS (temporary — remove once disk audit is complete)
# =========================================================
# [OPTIONAL] Enables GET /api/debug/disk — a read-only disk audit endpoint.
# Set to any strong random string; pass as x-debug-secret request header.
# Remove or leave empty once the orphaned-file investigation is complete.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
DEBUG_SECRET=""

# =========================================================
# KEEP-ALIVE (Render free tier)
# =========================================================
# [OPTIONAL] URL to ping every 10 minutes to prevent cold starts.
# Set to your backend /health endpoint during active outreach periods.
# Example: https://your-app.onrender.com/health
# Leave empty to disable — the ping loop will not start.
KEEP_ALIVE_URL=""

# =========================================================
# OBSERVABILITY
# =========================================================
# [OPTIONAL] debug | info | warn | error
LOG_LEVEL="debug"
# [OPTIONAL] Sentry DSN — leave empty to disable error reporting
SENTRY_DSN=""

# =========================================================
# PYTHON / ANALYSIS
# =========================================================
# [OPTIONAL] Path to Python binary for the audio analysis worker
PYTHON_BIN="/usr/bin/python3"
# [OPTIONAL] Legacy alias for audio directory — prefer AUDIO_STORAGE_PATH above
AUDIO_DIR="/path/to/audio"

# =========================================================
# RIGHTS ENRICHMENT PIPELINE
# =========================================================
# [OPTIONAL] Discogs API token — get one at https://www.discogs.com/settings/developers
DISCOGS_TOKEN=
# [OPTIONAL] Last.fm API key — get one at https://www.last.fm/api/account/create
LASTFM_API_KEY=
# [OPTIONAL] Genius API access token — get one at https://genius.com/api-clients
GENIUS_ACCESS_TOKEN=
