generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  schemas  = ["scoring"]
}

model User {
  id               String   @id @default(cuid())
  email            String   @unique
  passwordHash     String
  planLevel        String   @default("COMPOSER")
  stripeCustomerId String?
  creditBalance    Int      @default(0)
  createdAt        DateTime @default(now())

  ownedCatalogs      Catalog[]           @relation("CatalogOwner")
  catalogMembers     CatalogMember[]
  creditTransactions CreditTransaction[]

  @@schema("scoring")
}

model Catalog {
  id        String   @id @default(cuid())
  name      String
  ownerId   String
  owner     User     @relation("CatalogOwner", fields: [ownerId], references: [id])
  createdAt DateTime @default(now())

  members CatalogMember[]
  tracks  Track[]

  @@schema("scoring")
}

model CatalogMember {
  id        String  @id @default(cuid())
  catalogId String
  catalog   Catalog @relation(fields: [catalogId], references: [id], onDelete: Cascade)
  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      String

  @@unique([catalogId, userId])
  @@schema("scoring")
}

model Track {
  id              String   @id @default(cuid())
  title           String
  artistName      String?
  isrc            String
  trackStatus     String   @default("uploaded")

  audioFilePath   String?
  timeline        Json?
  errorReason     String?

  tempo             Float?
  tonalCharacter    String?
  energyCharacter   String?
  modelVersion      String?

  spectralCentroid  Float?
  rmsEnergy         Float?
  zeroCrossingRate  Float?

  catalogId       String?
  catalog         Catalog? @relation(fields: [catalogId], references: [id])

  rightsProfile   RightsProfile?
  confidenceScore ConfidenceScore?

  @@unique([catalogId, isrc])
  @@map("ScoringTrack")
  @@schema("scoring")
}

model RightsProfile {
  id                 String   @id @default(cuid())
  trackId            String   @unique
  track              Track    @relation(fields: [trackId], references: [id])

  ascapWorkId        String?
  bmiWorkId          String?
  masterOwnershipPct Decimal?
  isOneStop          Boolean?

  writerName         String?
  writerIpi          String?
  publisherName      String?
  proAffiliation     String?

  masterOwnedBy         String?
  masterOwnershipType   String?
  masterVerifiedAt      DateTime?
  masterOwnershipSplits Json?

  @@schema("scoring")
}

model ConfidenceScore {
  id                String   @id @default(cuid())
  trackId           String   @unique
  track             Track    @relation(fields: [trackId], references: [id])

  score             Int
  confidenceLabel   String
  inputHash         String

  rightsBreakdown   Int
  metaBreakdown     Int
  audioBreakdown    Int
  sceneFitBreakdown Int

  explanation       String
  createdAt         DateTime @default(now())
  hashVersion       Int      @default(1)

  @@schema("scoring")
}

// Idempotency ledger — prevents duplicate processing of Stripe retries.
// Primary key on eventId is the concurrency lock: a second insert for the
// same event.id fails at DB level even under concurrent requests.
// The type column enables operational debugging without hitting Stripe API.
model StripeEvent {
  eventId   String   @id
  type      String
  createdAt DateTime @default(now())

  @@map("stripe_events")
  @@schema("scoring")
}

// Server-authoritative trial state. Frontend stores only the opaque trialToken.
model UserTrial {
  trialToken String   @id @default(cuid())
  startedAt  DateTime @default(now())
  expiresAt  DateTime
  tracksUsed Int      @default(0)
  scenesUsed Int      @default(0)

  @@map("user_trials")
  @@schema("scoring")
}

// Full processing audit trail for every Stripe event.
// Distinct from stripe_events (ingestion dedup): this tracks processing state
// so the reconciliation cron can find missed or failed events.
model StripeEventLedger {
  id              String    @id                 // Stripe event.id
  type            String
  processed       Boolean   @default(false)
  processingError String?
  source          String                        // "webhook" | "reconciliation"
  createdAt       DateTime  @default(now())
  processedAt     DateTime?

  @@index([processed])
  @@index([type])
  @@map("stripe_event_ledger")
  @@schema("scoring")
}

// Immutable audit trail — every reconciliation action, repair, and drift
// detection event is appended here and never mutated.
model StripeAuditLog {
  id        String   @id @default(cuid())
  eventId   String?
  action    String
  result    String
  metadata  Json
  createdAt DateTime @default(now())

  @@index([eventId])
  @@index([action])
  @@map("stripe_audit_log")
  @@schema("scoring")
}

// Append-only ledger for every credit top-up. Never mutated after insert.
// creditBalance on User is the live counter; this table is the audit trail.
model CreditTransaction {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  packId     String
  credits    Int
  stripeEventId String @unique
  createdAt  DateTime @default(now())

  @@index([userId])
  @@map("credit_transactions")
  @@schema("scoring")
}