generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  schemas  = ["scoring"]
}

model User {
  id                 String              @id @default(cuid())
  email              String              @unique
  passwordHash       String
  planLevel          String              @default("COMPOSER")
  createdAt          DateTime            @default(now())
  stripeCustomerId   String?
  creditBalance      Int                 @default(0)
  ownedCatalogs      Catalog[]           @relation("CatalogOwner")
  catalogMembers     CatalogMember[]
  creditTransactions CreditTransaction[]

  @@schema("scoring")
}

model Catalog {
  id        String          @id @default(cuid())
  name      String
  ownerId   String
  createdAt DateTime        @default(now())
  owner     User            @relation("CatalogOwner", fields: [ownerId], references: [id])
  members   CatalogMember[]
  tracks    Track[]

  @@schema("scoring")
}

model CatalogMember {
  id        String  @id @default(cuid())
  catalogId String
  userId    String
  role      String
  catalog   Catalog @relation(fields: [catalogId], references: [id], onDelete: Cascade)
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([catalogId, userId])
  @@schema("scoring")
}

model Track {
  id               String           @id @default(cuid())
  title            String
  artistName       String?
  isrc             String
  trackStatus      String           @default("uploaded")
  audioFilePath    String?
  timeline         Json?
  errorReason      String?
  tempo            Float?
  tonalCharacter   String?
  energyCharacter  String?
  catalogId        String?
  modelVersion     String?
  rmsEnergy        Float?
  spectralCentroid Float?
  zeroCrossingRate Float?
  confidenceScore  ConfidenceScore?
  rightsProfile    RightsProfile?
  catalog          Catalog?         @relation(fields: [catalogId], references: [id])

  @@unique([catalogId, isrc])
  @@map("ScoringTrack")
  @@schema("scoring")
}

model RightsProfile {
  id                    String    @id @default(cuid())
  trackId               String    @unique
  ascapWorkId           String?
  masterOwnershipPct    Decimal?
  isOneStop             Boolean?
  writerName            String?
  writerIpi             String?
  publisherName         String?
  proAffiliation        String?
  bmiWorkId             String?
  masterOwnedBy         String?
  masterOwnershipSplits Json?
  masterOwnershipType   String?
  masterVerifiedAt      DateTime?
  track                 Track     @relation(fields: [trackId], references: [id])

  @@schema("scoring")
}

model ConfidenceScore {
  id                String   @id @default(cuid())
  trackId           String   @unique
  score             Int
  confidenceLabel   String
  inputHash         String
  rightsBreakdown   Int
  metaBreakdown     Int
  audioBreakdown    Int
  sceneFitBreakdown Int
  explanation       String
  createdAt         DateTime @default(now())
  hashVersion       Int      @default(1)
  track             Track    @relation(fields: [trackId], references: [id])

  @@schema("scoring")
}

model StripeEvent {
  eventId   String   @id
  type      String
  createdAt DateTime @default(now())

  @@map("stripe_events")
  @@schema("scoring")
}

model UserTrial {
  trialToken String   @id @default(cuid())
  startedAt  DateTime @default(now())
  expiresAt  DateTime
  tracksUsed Int      @default(0)
  scenesUsed Int      @default(0)

  @@map("user_trials")
  @@schema("scoring")
}

model StripeEventLedger {
  id              String    @id
  type            String
  processed       Boolean   @default(false)
  processingError String?
  source          String
  createdAt       DateTime  @default(now())
  processedAt     DateTime?

  @@index([processed])
  @@index([type])
  @@map("stripe_event_ledger")
  @@schema("scoring")
}

model StripeAuditLog {
  id        String   @id @default(cuid())
  eventId   String?
  action    String
  result    String
  metadata  Json
  createdAt DateTime @default(now())

  @@index([eventId])
  @@index([action])
  @@map("stripe_audit_log")
  @@schema("scoring")
}

model CreditTransaction {
  id            String   @id @default(cuid())
  userId        String
  packId        String
  credits       Int
  stripeEventId String   @unique
  createdAt     DateTime @default(now())
  user          User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("credit_transactions")
  @@schema("scoring")
}
